<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="800.0" prefWidth="1200.0" styleClass="main-layout-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.raez.finance.controller.FinanceMainLayoutController">

   <BorderPane>
      <left>
         <VBox fx:id="sidebarContainer" prefWidth="256.0" styleClass="main-sidebar-host" BorderPane.alignment="CENTER" />
      </left>

      <center>
         <BorderPane BorderPane.alignment="CENTER">

            <top>
               <VBox fx:id="topBarContainer" prefHeight="70.0" styleClass="main-topbar-host" BorderPane.alignment="CENTER" />
            </top>

            <center>
               <StackPane fx:id="contentArea" BorderPane.alignment="CENTER">
                  <padding>
                     <Insets bottom="32.0" left="32.0" right="12.0" top="32.0" />
                  </padding>
               </StackPane>
            </center>

            <bottom>
               <VBox fx:id="footerContainer" BorderPane.alignment="CENTER" />
            </bottom>

         </BorderPane>
      </center>
   </BorderPane>

   <StackPane fx:id="sessionWarningOverlay" managed="false" maxHeight="Infinity" maxWidth="Infinity" pickOnBounds="false" visible="false" styleClass="session-warning-overlay" />

</StackPane>
