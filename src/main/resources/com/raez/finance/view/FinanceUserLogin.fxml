<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>

<!--
  FinanceUserLogin.fxml — dark glassmorphism redesign
  ALL fx:id and onAction references preserved from original.
  Uses sapphire (#2563EB) accent instead of emerald for visual differentiation from FinanceAdminLogin.
  Three card sections preserved: loginCard, forgotFlowCard, passwordChangeCard.
-->
<StackPane
    style="-fx-background-color: #040D1C;"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.raez.finance.controller.FinanceUserLoginController">

    <Pane fx:id="animatedBg" mouseTransparent="true"
          style="-fx-background-color: transparent;" />

    <Pane mouseTransparent="true"
          style="-fx-background-color:
                 linear-gradient(from 0% 0% to 100% 100%,
                 rgba(37,99,235,0.05) 0%, transparent 50%,
                 rgba(16,185,129,0.04) 100%);" />

    <VBox alignment="CENTER">

        <!-- ══ LOGIN CARD ══ -->
        <VBox fx:id="loginCard"
              alignment="CENTER_LEFT"
              maxWidth="440"
              opacity="0">
            <padding><Insets top="24" right="0" bottom="24" left="0" /></padding>

            <HBox alignment="CENTER_LEFT">
                <VBox.margin><Insets bottom="14" /></VBox.margin>
                <Button fx:id="btnBackToRole"
                        text="← Back to Role Selection"
                        onAction="#handleBack"
                        style="-fx-background-color: rgba(255,255,255,0.06);
                               -fx-text-fill: rgba(255,255,255,0.55);
                               -fx-cursor: hand; -fx-font-size: 12.5px;
                               -fx-border-color: transparent;
                               -fx-background-radius: 7; -fx-padding: 6 12 6 12;" />
            </HBox>

            <VBox fx:id="loginView" spacing="22"
                  style="-fx-background-color: rgba(255,255,255,0.06);
                         -fx-background-radius: 18;
                         -fx-border-color: rgba(255,255,255,0.12);
                         -fx-border-radius: 18; -fx-border-width: 1;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 36, 0, 0, 10);">
                <padding><Insets top="0" right="36" bottom="36" left="36" /></padding>

                <!-- Sapphire top accent bar -->
                <Region prefHeight="4"
                        style="-fx-background-color: linear-gradient(to right, #2563EB, rgba(37,99,235,0.20));
                               -fx-background-radius: 18 18 0 0;" />

                <VBox alignment="CENTER" spacing="8">
                    <VBox.margin><Insets top="8" /></VBox.margin>
                    <StackPane prefWidth="56" prefHeight="56" maxWidth="56"
                               style="-fx-background-color: rgba(37,99,235,0.18);
                                      -fx-background-radius: 14;
                                      -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.35), 14, 0, 0, 0);">
                        <VBox.margin><Insets bottom="6" /></VBox.margin>
                        <SVGPath content="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
                                 fill="TRANSPARENT" stroke="#60A5FA"
                                 strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                 strokeWidth="2.2" scaleX="1.1" scaleY="1.1" />
                    </StackPane>
                    <Label text="Finance FinanceUser FinanceLogin"
                           style="-fx-font-size: 21px; -fx-font-weight: 700; -fx-text-fill: white;">
                        <font><Font name="System Bold" size="21" /></font>
                    </Label>
                    <Label text="Reports &amp; analytics access"
                           style="-fx-font-size: 12.5px; -fx-text-fill: rgba(255,255,255,0.42);" />
                </VBox>

                <VBox spacing="14">

                    <VBox spacing="6">
                        <Label text="Email / Username"
                               style="-fx-font-size: 11.5px; -fx-font-weight: 700;
                                      -fx-text-fill: rgba(255,255,255,0.60);" />
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 9;
                                     -fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 9;
                                     -fx-padding: 0 12 0 12;">
                            <SVGPath content="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6"
                                     fill="TRANSPARENT" stroke="rgba(255,255,255,0.30)"
                                     strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                            <TextField fx:id="txtEmail"
                                       promptText="d.hughes@raez.org.uk"
                                       prefHeight="40"
                                       style="-fx-background-color: transparent; -fx-border-color: transparent;
                                              -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.28);
                                              -fx-font-size: 13px; -fx-padding: 0 0 0 10;"
                                       HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Password"
                               style="-fx-font-size: 11.5px; -fx-font-weight: 700;
                                      -fx-text-fill: rgba(255,255,255,0.60);" />
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 9;
                                     -fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 9;
                                     -fx-padding: 0 12 0 12;">
                            <SVGPath content="M19 11H5a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2z M7 11V7a5 5 0 0 1 10 0v4"
                                     fill="TRANSPARENT" stroke="rgba(255,255,255,0.30)"
                                     strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                            <PasswordField fx:id="txtPassword"
                                           promptText="Enter your password"
                                           prefHeight="40"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;
                                                  -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.28);
                                                  -fx-font-size: 13px; -fx-padding: 0 0 0 10;"
                                           HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT">
                        <Hyperlink fx:id="linkForgotPassword"
                                   text="Forgot password?"
                                   onAction="#handleForgotPassword"
                                   style="-fx-text-fill: rgba(96,165,250,0.80);
                                          -fx-border-color: transparent; -fx-font-size: 12px;" />
                    </HBox>

                    <VBox fx:id="loginErrorBox" managed="false" visible="false"
                          style="-fx-background-color: rgba(239,68,68,0.12);
                                 -fx-border-color: rgba(239,68,68,0.35);
                                 -fx-border-radius: 9; -fx-background-radius: 9;">
                        <padding><Insets top="12" right="16" bottom="12" left="16" /></padding>
                        <HBox spacing="8" alignment="TOP_LEFT">
                            <SVGPath content="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z M12 8v4 M12 16h.01"
                                     fill="TRANSPARENT" stroke="#EF4444"
                                     strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                            <Label fx:id="lblLoginError"
                                   text="Invalid credentials"
                                   textFill="#FCA5A5"
                                   wrapText="true"
                                   maxWidth="340"
                                   style="-fx-font-size: 13px;"
                                   HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                    <!-- FinanceLogin button — sapphire fill -->
                    <Button fx:id="btnLogin"
                            text="FinanceLogin as Finance FinanceUser"
                            maxWidth="Infinity"
                            prefHeight="46"
                            onAction="#handleLogin"
                            style="-fx-background-color: #2563EB;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 9;
                                   -fx-font-size: 13.5px;
                                   -fx-font-weight: 700;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.40), 14, 0, 0, 3);">
                        <VBox.margin><Insets top="4" /></VBox.margin>
                    </Button>

                    <HBox alignment="CENTER">
                        <Button fx:id="btnDemoCredentials"
                                text="Fill demo credentials"
                                onAction="#handleAddDemoCredentials"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: rgba(255,255,255,0.38);
                                       -fx-border-color: rgba(255,255,255,0.12);
                                       -fx-border-radius: 8; -fx-background-radius: 8;
                                       -fx-font-size: 11.5px; -fx-cursor: hand;
                                       -fx-padding: 7 16 7 16;" />
                    </HBox>

                </VBox>

                <!-- Info notice -->
                <VBox style="-fx-background-color: rgba(37,99,235,0.10);
                             -fx-border-color: rgba(37,99,235,0.25);
                             -fx-border-radius: 8; -fx-background-radius: 8;">
                    <padding><Insets top="10" right="14" bottom="10" left="14" /></padding>
                    <Label text="First-time users will be prompted to set a new password after login."
                           textFill="rgba(147,197,253,0.80)"
                           wrapText="true"
                           style="-fx-font-size: 11.5px;" />
                </VBox>

            </VBox>
        </VBox>

        <!-- ══ FORGOT PASSWORD CARD ══ -->
        <VBox fx:id="forgotFlowCard" alignment="CENTER_LEFT" maxWidth="440"
              managed="false" visible="false">
            <padding><Insets top="24" right="0" bottom="24" left="0" /></padding>
            <Button text="← Back to login" onAction="#handleForgotBackToLogin"
                    style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: rgba(255,255,255,0.55);
                           -fx-cursor: hand; -fx-font-size: 12.5px; -fx-border-color: transparent;
                           -fx-background-radius: 7; -fx-padding: 6 12 6 12;">
                <VBox.margin><Insets bottom="14" /></VBox.margin>
            </Button>
            <VBox spacing="18"
                  style="-fx-background-color: rgba(255,255,255,0.06);
                         -fx-background-radius: 18;
                         -fx-border-color: rgba(255,255,255,0.12);
                         -fx-border-radius: 18; -fx-border-width: 1;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 36, 0, 0, 10);">
                <padding><Insets top="32" right="32" bottom="32" left="32" /></padding>
                <Label text="Reset password"
                       style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: white;" />
                <Label text="Enter your account and we'll send a one-time code."
                       wrapText="true"
                       style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.42);" />

                <VBox fx:id="forgotPaneSend" spacing="12">
                    <VBox spacing="6">
                        <Label text="Account (email or username)"
                               style="-fx-font-size: 11.5px; -fx-font-weight: 700; -fx-text-fill: rgba(255,255,255,0.60);" />
                        <TextField fx:id="txtForgotAccount"
                                   promptText="e.g. finance@raez.org.uk or username"
                                   prefHeight="40"
                                   style="-fx-background-color: rgba(255,255,255,0.06);
                                          -fx-border-color: rgba(255,255,255,0.12);
                                          -fx-border-radius: 9; -fx-background-radius: 9;
                                          -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.28);
                                          -fx-font-size: 13px; -fx-padding: 0 12 0 12;" />
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Send code to (email)"
                               style="-fx-font-size: 11.5px; -fx-font-weight: 700; -fx-text-fill: rgba(255,255,255,0.60);" />
                        <TextField fx:id="txtForgotSendTo"
                                   promptText="Leave blank to use account email"
                                   prefHeight="40"
                                   style="-fx-background-color: rgba(255,255,255,0.06);
                                          -fx-border-color: rgba(255,255,255,0.12);
                                          -fx-border-radius: 9; -fx-background-radius: 9;
                                          -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.28);
                                          -fx-font-size: 13px; -fx-padding: 0 12 0 12;" />
                    </VBox>
                    <Button fx:id="btnForgotSend" text="Send reset email" maxWidth="Infinity"
                            prefHeight="46" onAction="#handleForgotSendEmail"
                            style="-fx-background-color: #2563EB; -fx-text-fill: white;
                                   -fx-background-radius: 9; -fx-font-weight: 700; -fx-cursor: hand;" />
                    <Label fx:id="lblForgotSendCountdown" managed="false" visible="false" text=""
                           style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.45);" />
                </VBox>

                <VBox fx:id="forgotPaneToken" spacing="12" managed="false" visible="false">
                    <Label text="Enter the code from your email"
                           style="-fx-font-size: 11.5px; -fx-font-weight: 700; -fx-text-fill: rgba(255,255,255,0.60);" />
                    <TextField fx:id="txtForgotToken" promptText="Reset token" prefHeight="40"
                               style="-fx-background-color: rgba(255,255,255,0.06);
                                      -fx-border-color: rgba(255,255,255,0.12);
                                      -fx-border-radius: 9; -fx-background-radius: 9;
                                      -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.28);
                                      -fx-font-size: 13px; -fx-padding: 0 12 0 12;" />
                    <PasswordField fx:id="txtForgotNewPassword"
                                   promptText="New password (min 8 characters)" prefHeight="40"
                                   style="-fx-background-color: rgba(255,255,255,0.06);
                                          -fx-border-color: rgba(255,255,255,0.12);
                                          -fx-border-radius: 9; -fx-background-radius: 9;
                                          -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 0 12 0 12;" />
                    <PasswordField fx:id="txtForgotConfirmPassword"
                                   promptText="Confirm new password" prefHeight="40"
                                   style="-fx-background-color: rgba(255,255,255,0.06);
                                          -fx-border-color: rgba(255,255,255,0.12);
                                          -fx-border-radius: 9; -fx-background-radius: 9;
                                          -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 0 12 0 12;" />
                    <Button fx:id="btnForgotApplyReset" text="Update password" maxWidth="Infinity"
                            prefHeight="46" onAction="#handleForgotApplyReset"
                            style="-fx-background-color: #10B981; -fx-text-fill: white;
                                   -fx-background-radius: 9; -fx-font-weight: 700; -fx-cursor: hand;" />
                </VBox>
            </VBox>
        </VBox>

        <!-- ══ SET PASSWORD CARD (first-time login) ══ -->
        <VBox fx:id="passwordChangeCard"
              alignment="CENTER_LEFT"
              maxWidth="440"
              managed="false" visible="false">
            <padding><Insets top="24" right="0" bottom="24" left="0" /></padding>

            <VBox fx:id="passwordChangeView" spacing="22"
                  style="-fx-background-color: rgba(255,255,255,0.06);
                         -fx-background-radius: 18;
                         -fx-border-color: rgba(255,255,255,0.12);
                         -fx-border-radius: 18; -fx-border-width: 1;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 36, 0, 0, 10);">
                <padding><Insets top="0" right="36" bottom="36" left="36" /></padding>

                <!-- Emerald top bar — new password = success colour -->
                <Region prefHeight="4"
                        style="-fx-background-color: linear-gradient(to right, #10B981, rgba(16,185,129,0.20));
                               -fx-background-radius: 18 18 0 0;" />

                <VBox alignment="CENTER" spacing="8">
                    <VBox.margin><Insets top="8" /></VBox.margin>
                    <StackPane prefWidth="56" prefHeight="56" maxWidth="56"
                               style="-fx-background-color: rgba(16,185,129,0.18);
                                      -fx-background-radius: 14;
                                      -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.35), 14, 0, 0, 0);">
                        <VBox.margin><Insets bottom="6" /></VBox.margin>
                        <SVGPath content="M19 11H5a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2z M7 11V7a5 5 0 0 1 10 0v4 M12 16v-3"
                                 fill="TRANSPARENT" stroke="#10B981"
                                 strokeLineCap="ROUND" strokeLineJoin="ROUND"
                                 strokeWidth="2.2" scaleX="1.1" scaleY="1.1" />
                    </StackPane>
                    <Label text="Set Your Password"
                           style="-fx-font-size: 21px; -fx-font-weight: 700; -fx-text-fill: white;">
                        <font><Font name="System Bold" size="21" /></font>
                    </Label>
                    <Label text="First-time login — choose a strong password"
                           style="-fx-font-size: 12.5px; -fx-text-fill: rgba(255,255,255,0.42);" />
                </VBox>

                <!-- Requirements banner -->
                <VBox style="-fx-background-color: rgba(37,99,235,0.10);
                             -fx-border-color: rgba(37,99,235,0.25);
                             -fx-border-radius: 8; -fx-background-radius: 8;">
                    <padding><Insets top="10" right="14" bottom="10" left="14" /></padding>
                    <Label text="Min 8 chars · 1 uppercase · 1 lowercase · 1 digit · 1 symbol"
                           textFill="rgba(147,197,253,0.80)"
                           style="-fx-font-size: 11.5px;" wrapText="true" />
                </VBox>

                <VBox spacing="14">
                    <VBox spacing="6">
                        <Label text="New Password"
                               style="-fx-font-size: 11.5px; -fx-font-weight: 700;
                                      -fx-text-fill: rgba(255,255,255,0.60);" />
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 9;
                                     -fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 9;
                                     -fx-padding: 0 12 0 12;">
                            <SVGPath content="M19 11H5a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2z M7 11V7a5 5 0 0 1 10 0v4"
                                     fill="TRANSPARENT" stroke="rgba(255,255,255,0.30)"
                                     strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                            <PasswordField fx:id="txtNewPassword" promptText="New password" prefHeight="40"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;
                                                  -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.28);
                                                  -fx-font-size: 13px; -fx-padding: 0 0 0 10;"
                                           HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Confirm Password"
                               style="-fx-font-size: 11.5px; -fx-font-weight: 700;
                                      -fx-text-fill: rgba(255,255,255,0.60);" />
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 9;
                                     -fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 9;
                                     -fx-padding: 0 12 0 12;">
                            <SVGPath content="M19 11H5a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2z M7 11V7a5 5 0 0 1 10 0v4"
                                     fill="TRANSPARENT" stroke="rgba(255,255,255,0.30)"
                                     strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                            <PasswordField fx:id="txtConfirmPassword" promptText="Confirm password" prefHeight="40"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;
                                                  -fx-text-fill: white; -fx-prompt-text-fill: rgba(255,255,255,0.28);
                                                  -fx-font-size: 13px; -fx-padding: 0 0 0 10;"
                                           HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                    <VBox fx:id="pwdErrorBox" managed="false" visible="false"
                          style="-fx-background-color: rgba(239,68,68,0.12);
                                 -fx-border-color: rgba(239,68,68,0.35);
                                 -fx-border-radius: 9; -fx-background-radius: 9;">
                        <padding><Insets top="12" right="16" bottom="12" left="16" /></padding>
                        <Label fx:id="lblPwdError"
                               text="Passwords do not match"
                               textFill="#FCA5A5"
                               wrapText="true"
                               maxWidth="340"
                               style="-fx-font-size: 13px;" />
                    </VBox>

                    <Button fx:id="btnSetPassword"
                            text="Set Password &amp; Continue"
                            maxWidth="Infinity"
                            prefHeight="46"
                            onAction="#handlePasswordChange"
                            style="-fx-background-color: #10B981;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 9;
                                   -fx-font-size: 13.5px;
                                   -fx-font-weight: 700;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.40), 14, 0, 0, 3);">
                        <VBox.margin><Insets top="4" /></VBox.margin>
                    </Button>
                </VBox>
            </VBox>
        </VBox>

    </VBox>
</StackPane>
