<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #F9FAFB;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.raez.finance.controller.FinanceInvoicesController">
    <content>
        <StackPane>
            <children>
        <VBox spacing="24.0" style="-fx-background-color: #F9FAFB;">
            <padding>
                <Insets top="28.0" right="28.0" bottom="32.0" left="28.0" />
            </padding>
            <children>

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <children>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="page-title" text="FinanceInvoices" />
                                <Label styleClass="page-subtitle" text="Issued invoices and payment status" />
                            </children>
                        </VBox>

                        <Button fx:id="btnGenerateInvoice" mnemonicParsing="false" onAction="#handleGenerateInvoice" styleClass="primary-button" text="Generate New Invoice" />

                        <MenuButton fx:id="exportMenuButton"
                                    mnemonicParsing="false"
                                    styleClass="export-menu-button"
                                    text="Export">
                            <graphic>
                                <SVGPath content="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"
                                         fill="TRANSPARENT" stroke="white"
                                         strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                            </graphic>
                            <items>
                                <MenuItem fx:id="exportCsvItem" mnemonicParsing="false" onAction="#handleExportCsv" styleClass="export-menu-item" text="Export as CSV">
                                    <graphic>
                                        <SVGPath content="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                                 fill="TRANSPARENT" stroke="#10B981"
                                                 strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" />
                                    </graphic>
                                </MenuItem>
                                <MenuItem fx:id="exportPdfItem" mnemonicParsing="false" onAction="#handleExportPdf" styleClass="export-menu-item" text="Export as PDF">
                                    <graphic>
                                        <SVGPath content="M14 3v4a1 1 0 0 0 1 1h4 M5 12V5a2 2 0 0 1 2-2h7l5 5v4 M5 18h1.5a1.5 1.5 0 0 0 0-3H5v6 M17 18h2 M20 15h-3v6 M11 15v6h1a2 2 0 0 0 2-2v-2a2 2 0 0 0-2-2h-1z"
                                                 fill="TRANSPARENT" stroke="#EF4444"
                                                 strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" />
                                    </graphic>
                                </MenuItem>
                            </items>
                        </MenuButton>
                    </children>
                </HBox>

                <!-- KPI strip -->
                <HBox spacing="16" styleClass="card" alignment="CENTER_LEFT">
                    <padding>
                        <Insets top="16" right="20" bottom="16" left="20" />
                    </padding>
                    <children>
                        <VBox spacing="4" prefWidth="160">
                            <Label text="TOTAL INVOICED" styleClass="kpi-title" />
                            <Label fx:id="lblKpiInvoiced" text="£0.00" styleClass="kpi-value" />
                        </VBox>
                        <VBox spacing="4" prefWidth="160">
                            <Label text="TOTAL PAID" styleClass="kpi-title" />
                            <Label fx:id="lblKpiPaid" text="£0.00" styleClass="kpi-value" />
                        </VBox>
                        <VBox spacing="4" prefWidth="160">
                            <Label text="OUTSTANDING" styleClass="kpi-title" />
                            <Label fx:id="lblKpiOutstanding" text="£0.00" styleClass="kpi-value" />
                        </VBox>
                        <VBox spacing="4" prefWidth="140">
                            <Label text="OVERDUE" styleClass="kpi-title" />
                            <Label fx:id="lblKpiOverdue" text="0" styleClass="kpi-value" />
                        </VBox>
                    </children>
                </HBox>

                <!-- Filter bar -->
                <VBox styleClass="filter-card">
                    <padding>
                        <Insets top="16.0" right="24.0" bottom="16.0" left="24.0" />
                    </padding>
                    <children>
                        <HBox alignment="BOTTOM_LEFT" spacing="14">
                            <children>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Search" textFill="#374151" style="-fx-font-size: 11px; -fx-font-weight: 700;" />
                                        <TextField fx:id="searchField" promptText="Invoice #, order ID, customer…"
                                                   styleClass="combo-box" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="Status" textFill="#374151" style="-fx-font-size: 11px; -fx-font-weight: 700;" />
                                        <ComboBox fx:id="statusCombo" prefWidth="140.0" prefHeight="34"
                                                  styleClass="combo-box" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="Date range" textFill="#374151" style="-fx-font-size: 11px; -fx-font-weight: 700;" />
                                        <ComboBox fx:id="dateRangeCombo" prefWidth="150.0" prefHeight="34"
                                                  styleClass="combo-box" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Table -->
                <VBox styleClass="reports-card">
                    <padding>
                        <Insets top="8.0" right="16.0" bottom="16.0" left="16.0" />
                    </padding>
                    <children>
                        <TableView fx:id="invoiceTable" styleClass="reports-table"
                                   style="-fx-background-color: transparent;
                                          -fx-table-cell-border-color: transparent;
                                          -fx-fixed-cell-size: 44;">
                            <columns>
                                <TableColumn fx:id="colInvoiceNumber" text="Invoice #" minWidth="110" />
                                <TableColumn fx:id="colOrderId"       text="Order ID"  minWidth="80" />
                                <TableColumn fx:id="colCustomer"      text="Customer"  minWidth="150" />
                                <TableColumn fx:id="colAmount"        text="Amount"    minWidth="100" />
                                <TableColumn fx:id="colStatus"        text="Status"    minWidth="100" />
                                <TableColumn fx:id="colDueDate"       text="Due Date"  minWidth="110" />
                                <TableColumn fx:id="colPaidAt"        text="Paid At"   minWidth="110" />
                                <TableColumn fx:id="colActions"       text="Actions"   minWidth="200" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>

            </children>
        </VBox>

                <ProgressIndicator fx:id="loadingIndicator" maxHeight="40" maxWidth="40"
                                   visible="false" managed="false"
                                   StackPane.alignment="CENTER" />
            </children>
        </StackPane>
    </content>
</ScrollPane>
