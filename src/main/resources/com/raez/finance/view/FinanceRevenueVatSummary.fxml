<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<!--
  ROOT is ScrollPane — requires:  <?import javafx.scene.control.ScrollPane?>
  This import was MISSING in the original file, causing the LoadException.
-->
<ScrollPane
    fx:id="pageScrollPane"
    fitToWidth="true"
    hbarPolicy="NEVER"
    vbarPolicy="AS_NEEDED"
    style="-fx-background-color: transparent; -fx-background: #F9FAFB;"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.raez.finance.controller.FinanceRevenueVatSummaryController">

    <content>
        <VBox spacing="24" style="-fx-background-color: #F9FAFB;">
            <padding><Insets top="28" right="28" bottom="32" left="28" /></padding>

            <!-- ══════════════════════════
                 HEADER
            ══════════════════════════ -->
            <HBox alignment="CENTER_LEFT" spacing="0">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Revenue Analysis &amp; VAT Summary"
                           style="-fx-font-size: 22px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                    <Label text="Gross vs net revenue and tax liabilities"
                           style="-fx-font-size: 13px; -fx-text-fill: #6B7280;" />
                </VBox>

                <MenuButton
                    fx:id="exportMenuButton"
                    mnemonicParsing="false"
                    styleClass="export-menu-button"
                    text="Export">
                    <graphic>
                        <SVGPath content="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" fill="TRANSPARENT" stroke="white" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                    </graphic>
                    <items>
                        <MenuItem fx:id="exportCsvItem" mnemonicParsing="false" onAction="#handleExportCsv" styleClass="export-menu-item" text="Export as CSV">
                            <graphic>
                                <SVGPath content="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" fill="TRANSPARENT" stroke="#10B981" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" />
                            </graphic>
                        </MenuItem>
                        <MenuItem fx:id="exportPdfItem" mnemonicParsing="false" onAction="#handleExportPdf" styleClass="export-menu-item" text="Export as PDF">
                            <graphic>
                                <SVGPath content="M14 3v4a1 1 0 0 0 1 1h4 M5 12V5a2 2 0 0 1 2-2h7l5 5v4 M5 18h1.5a1.5 1.5 0 0 0 0-3H5v6 M17 18h2 M20 15h-3v6 M11 15v6h1a2 2 0 0 0 2-2v-2a2 2 0 0 0-2-2h-1z" fill="TRANSPARENT" stroke="#EF4444" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2.0" />
                            </graphic>
                        </MenuItem>
                    </items>
                </MenuButton>
            </HBox>

            <!-- ══════════════════════════
                 FILTER CARD
            ══════════════════════════ -->
            <VBox style="-fx-background-color: white;
                         -fx-border-color: #E5E7EB; -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                <padding><Insets top="18" right="24" bottom="18" left="24" /></padding>

                <HBox alignment="BOTTOM_LEFT" spacing="14">

                    <VBox spacing="5" prefWidth="180">
                        <Label text="Date Range"
                               style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #374151;" />
                        <ComboBox fx:id="cmbDateRange"
                                  prefWidth="180" prefHeight="34"
                                  style="-fx-font-size: 13px;" />
                    </VBox>

                    <VBox fx:id="boxStartDate" spacing="5" prefWidth="152"
                          managed="false" visible="false">
                        <Label text="Start Date"
                               style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #374151;" />
                        <DatePicker fx:id="dpStartDate"
                                    prefWidth="152" prefHeight="34"
                                    style="-fx-font-size: 13px;" />
                    </VBox>

                    <VBox fx:id="boxEndDate" spacing="5" prefWidth="152"
                          managed="false" visible="false">
                        <Label text="End Date"
                               style="-fx-font-size: 11px; -fx-font-weight: 700; -fx-text-fill: #374151;" />
                        <DatePicker fx:id="dpEndDate"
                                    prefWidth="152" prefHeight="34"
                                    style="-fx-font-size: 13px;" />
                    </VBox>

                </HBox>
            </VBox>

            <!-- ══════════════════════════
                 KPI CARDS  (3 columns)
            ══════════════════════════ -->
            <GridPane hgap="20" vgap="20">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.33" />
                    <ColumnConstraints percentWidth="33.33" />
                    <ColumnConstraints percentWidth="33.34" />
                </columnConstraints>
                <rowConstraints><RowConstraints /></rowConstraints>

                <!-- Gross Revenue -->
                <VBox GridPane.columnIndex="0" spacing="6"
                      style="-fx-background-color: white;
                             -fx-border-color: #E5E7EB; -fx-border-radius: 10;
                             -fx-background-radius: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                    <padding><Insets top="22" right="24" bottom="22" left="24" /></padding>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="💰" style="-fx-font-size: 20px;" />
                        <VBox spacing="2">
                            <Label text="Gross Revenue"
                                   style="-fx-font-size: 11px; -fx-font-weight: 700;
                                          -fx-text-fill: #6B7280; -fx-text-transform: uppercase;" />
                            <Label fx:id="lblGrossRevenue" text="£0.00"
                                   style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                            <Label text="Including VAT"
                                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;" />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Net Revenue -->
                <VBox GridPane.columnIndex="1" spacing="6"
                      style="-fx-background-color: white;
                             -fx-border-color: #E5E7EB; -fx-border-radius: 10;
                             -fx-background-radius: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                    <padding><Insets top="22" right="24" bottom="22" left="24" /></padding>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="📈" style="-fx-font-size: 20px;" />
                        <VBox spacing="2">
                            <Label text="Net Revenue"
                                   style="-fx-font-size: 11px; -fx-font-weight: 700;
                                          -fx-text-fill: #6B7280; -fx-text-transform: uppercase;" />
                            <Label fx:id="lblNetRevenue" text="£0.00"
                                   style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                            <Label text="Excluding VAT"
                                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;" />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- VAT Collected -->
                <VBox GridPane.columnIndex="2" spacing="6"
                      style="-fx-background-color: white;
                             -fx-border-color: #E5E7EB; -fx-border-radius: 10;
                             -fx-background-radius: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                    <padding><Insets top="22" right="24" bottom="22" left="24" /></padding>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🏛" style="-fx-font-size: 20px;" />
                        <VBox spacing="2">
                            <Label text="VAT Collected"
                                   style="-fx-font-size: 11px; -fx-font-weight: 700;
                                          -fx-text-fill: #6B7280; -fx-text-transform: uppercase;" />
                            <Label fx:id="lblVatCollected" text="£0.00"
                                   style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                            <Label fx:id="lblVatRate" text="@ 20% VAT rate"
                                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;" />
                        </VBox>
                    </HBox>
                </VBox>
            </GridPane>

            <!-- ══════════════════════════
                 SECOND KPI ROW — margin & orders
            ══════════════════════════ -->
            <GridPane hgap="20" vgap="20">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.33" />
                    <ColumnConstraints percentWidth="33.33" />
                    <ColumnConstraints percentWidth="33.34" />
                </columnConstraints>
                <rowConstraints><RowConstraints /></rowConstraints>

                <!-- Profit Margin -->
                <VBox GridPane.columnIndex="0" spacing="6"
                      style="-fx-background-color: white;
                             -fx-border-color: #E5E7EB; -fx-border-radius: 10;
                             -fx-background-radius: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                    <padding><Insets top="22" right="24" bottom="22" left="24" /></padding>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="📊" style="-fx-font-size: 20px;" />
                        <VBox spacing="2">
                            <Label text="Gross Profit Margin"
                                   style="-fx-font-size: 11px; -fx-font-weight: 700;
                                          -fx-text-fill: #6B7280; -fx-text-transform: uppercase;" />
                            <Label fx:id="lblMargin" text="0.0%"
                                   style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #16A34A;" />
                            <Label text="(Net Revenue – COGS) / Net Revenue"
                                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;" />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Total Orders -->
                <VBox GridPane.columnIndex="1" spacing="6"
                      style="-fx-background-color: white;
                             -fx-border-color: #E5E7EB; -fx-border-radius: 10;
                             -fx-background-radius: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                    <padding><Insets top="22" right="24" bottom="22" left="24" /></padding>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🛒" style="-fx-font-size: 20px;" />
                        <VBox spacing="2">
                            <Label text="Total Orders"
                                   style="-fx-font-size: 11px; -fx-font-weight: 700;
                                          -fx-text-fill: #6B7280; -fx-text-transform: uppercase;" />
                            <Label fx:id="lblTotalOrders" text="0"
                                   style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                            <Label text="In the selected date range"
                                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;" />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Avg Order Value -->
                <VBox GridPane.columnIndex="2" spacing="6"
                      style="-fx-background-color: white;
                             -fx-border-color: #E5E7EB; -fx-border-radius: 10;
                             -fx-background-radius: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                    <padding><Insets top="22" right="24" bottom="22" left="24" /></padding>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🧾" style="-fx-font-size: 20px;" />
                        <VBox spacing="2">
                            <Label text="Avg Order Value"
                                   style="-fx-font-size: 11px; -fx-font-weight: 700;
                                          -fx-text-fill: #6B7280; -fx-text-transform: uppercase;" />
                            <Label fx:id="lblAvgOrder" text="£0.00"
                                   style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                            <Label text="Per completed order"
                                   style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;" />
                        </VBox>
                    </HBox>
                </VBox>
            </GridPane>

            <!-- ══════════════════════════
                 VAT BREAKDOWN TABLE
            ══════════════════════════ -->
            <VBox style="-fx-background-color: white;
                         -fx-border-color: #E5E7EB; -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">

                <HBox alignment="CENTER_LEFT" spacing="0"
                      style="-fx-border-color: transparent transparent #E5E7EB transparent;
                             -fx-border-width: 0 0 1 0; -fx-padding: 18 24 18 24;">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Revenue by Category"
                               style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                        <Label text="Gross revenue, VAT and net breakdown per product category"
                               style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;" />
                    </VBox>
                </HBox>

                <!--
                  columnResizePolicy set in controller:
                  tableVatBreakdown.setColumnResizePolicy(TableView.CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS)
                -->
                <TableView fx:id="tableVatBreakdown"
                           styleClass="reports-table"
                           style="-fx-background-color: transparent;
                                  -fx-table-cell-border-color: transparent;
                                  -fx-fixed-cell-size: 44;">
                    <columns>
                        <TableColumn fx:id="colVatCategory"     text="Category"        minWidth="130" />
                        <TableColumn fx:id="colVatOrders"       text="Orders"          minWidth="80" />
                        <TableColumn fx:id="colVatGross"        text="Gross Revenue"   minWidth="130" />
                        <TableColumn fx:id="colVatAmount"       text="VAT Collected"   minWidth="130" />
                        <TableColumn fx:id="colVatNet"          text="Net Revenue"     minWidth="130" />
                        <TableColumn fx:id="colVatMargin"       text="Margin %"        minWidth="100" />
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="8">
                            <Label text="No data available for the selected range"
                                   style="-fx-text-fill: #9CA3AF; -fx-font-size: 13px;" />
                        </VBox>
                    </placeholder>
                </TableView>

                <!-- Summary footer -->
                <HBox alignment="CENTER_LEFT" spacing="32"
                      style="-fx-border-color: #E5E7EB transparent transparent transparent;
                             -fx-border-width: 1 0 0 0; -fx-padding: 14 24 14 24;
                             -fx-background-color: #FAFAFA; -fx-background-radius: 0 0 10 10;">
                    <VBox spacing="2">
                        <Label text="TOTAL GROSS"
                               style="-fx-font-size: 10px; -fx-font-weight: 700; -fx-text-fill: #9CA3AF;" />
                        <Label fx:id="lblFooterGross" text="£0.00"
                               style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                    </VBox>
                    <VBox spacing="2">
                        <Label text="TOTAL VAT"
                               style="-fx-font-size: 10px; -fx-font-weight: 700; -fx-text-fill: #9CA3AF;" />
                        <Label fx:id="lblFooterVat" text="£0.00"
                               style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
                    </VBox>
                    <VBox spacing="2">
                        <Label text="TOTAL NET"
                               style="-fx-font-size: 10px; -fx-font-weight: 700; -fx-text-fill: #9CA3AF;" />
                        <Label fx:id="lblFooterNet" text="£0.00"
                               style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #16A34A;" />
                    </VBox>
                </HBox>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
