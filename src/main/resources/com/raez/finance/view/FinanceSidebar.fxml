<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.Font?>

<!--
  FinanceSidebar.fxml — redesigned
  Changes from original:
    - "Support & Alerts" (btnAlerts) REMOVED per redesign spec
    - All nav buttons wired to FinanceSidebarController hover animations (programmatic, not CSS)
    - Logout gets red-tint hover via addLogoutHover()
    - No other structural changes
-->
<VBox maxHeight="Infinity" prefWidth="256.0"
      style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-width: 0 1 0 0;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.raez.finance.controller.FinanceSidebarController">
   <children>

      <!-- BRAND HEADER -->
      <VBox style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;">
         <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>
         <children>
            <Label text="RAEZ Finance" textFill="#111827">
               <font><Font name="System Bold" size="20.0" /></font>
            </Label>
            <Label text="Portal System" textFill="#4B5563">
               <font><Font size="14.0" /></font>
               <VBox.margin><Insets top="4.0" /></VBox.margin>
            </Label>
         </children>
      </VBox>

      <!-- NAV ITEMS -->
      <VBox spacing="4.0" style="-fx-background-color: white;" VBox.vgrow="ALWAYS">
         <padding><Insets bottom="16.0" left="12.0" right="12.0" top="16.0" /></padding>
         <children>

            <!-- 1. Dashboard (active on load) -->
            <Button fx:id="btnDashboard"
                    alignment="BASELINE_LEFT" graphicTextGap="12.0" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleNavDashboard" prefHeight="45.0"
                    style="-fx-background-color: #1E2939; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand;"
                    text="Dashboard">
               <graphic>
                  <StackPane minWidth="24.0" minHeight="24.0" mouseTransparent="true">
                     <children>
                        <SVGPath content="M4 5a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1v-4zm10 0a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z"
                                 fill="TRANSPARENT" stroke="white" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                     </children>
                  </StackPane>
               </graphic>
               <font><Font size="14.0" /></font>
            </Button>

            <!-- 2. Reports -->
            <Button fx:id="btnReports"
                    alignment="BASELINE_LEFT" graphicTextGap="12.0" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleNavReports" prefHeight="45.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-cursor: hand;"
                    text="Reports">
               <graphic>
                  <StackPane minWidth="24.0" minHeight="24.0" mouseTransparent="true">
                     <children>
                        <SVGPath content="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8"
                                 fill="TRANSPARENT" stroke="#374151" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                     </children>
                  </StackPane>
               </graphic>
               <font><Font size="14.0" /></font>
            </Button>

            <!-- 3. Analytics (collapsible) -->
            <Button fx:id="btnAnalytics"
                    alignment="BASELINE_LEFT" graphicTextGap="12.0" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleToggleAnalytics" prefHeight="45.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-cursor: hand;"
                    text="Analytics">
               <graphic>
                  <HBox alignment="CENTER_LEFT" spacing="6" mouseTransparent="true">
                     <children>
                        <SVGPath fx:id="analyticsIcon"
                                 content="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                                 fill="TRANSPARENT" stroke="#374151" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                        <SVGPath fx:id="chevronIcon"
                                 content="M19 9l-7 7-7-7"
                                 fill="TRANSPARENT" stroke="#374151" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="2" />
                     </children>
                  </HBox>
               </graphic>
               <font><Font size="14.0" /></font>
            </Button>

            <!-- Analytics children -->
            <VBox fx:id="analyticsChildBox" managed="false" visible="false" spacing="2">
               <padding><Insets left="20.0" /></padding>
               <children>
                  <Button fx:id="btnInsights" alignment="BASELINE_LEFT" graphicTextGap="12.0" maxWidth="Infinity"
                          mnemonicParsing="false" onAction="#handleNavInsights" prefHeight="40.0"
                          style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;"
                          text="Customer Insights">
                     <graphic>
                        <StackPane minWidth="20.0" minHeight="20.0" mouseTransparent="true">
                           <children>
                              <SVGPath content="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M9 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8z M23 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75"
                                        fill="TRANSPARENT" stroke="#374151" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                           </children>
                        </StackPane>
                     </graphic>
                  </Button>
                  <Button fx:id="btnProfitability" alignment="BASELINE_LEFT" graphicTextGap="12.0" maxWidth="Infinity"
                          mnemonicParsing="false" onAction="#handleNavProfitability" prefHeight="40.0"
                          style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;"
                          text="Product Profitability">
                     <graphic>
                        <StackPane minWidth="20.0" minHeight="20.0" mouseTransparent="true">
                           <children>
                              <SVGPath content="M23 6l-9.5 9.5-5-5L1 18 M17 6h6v6"
                                        fill="TRANSPARENT" stroke="#374151" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                           </children>
                        </StackPane>
                     </graphic>
                  </Button>
                  <Button fx:id="btnRevenueVat" alignment="BASELINE_LEFT" graphicTextGap="12.0" maxWidth="Infinity"
                          mnemonicParsing="false" onAction="#handleNavRevenueVat" prefHeight="40.0"
                          style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;"
                          text="Revenue &amp; VAT">
                     <graphic>
                        <StackPane minWidth="20.0" minHeight="20.0" mouseTransparent="true">
                           <children>
                              <SVGPath content="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                        fill="TRANSPARENT" stroke="#374151" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                           </children>
                        </StackPane>
                     </graphic>
                  </Button>
                  <Button fx:id="btnInventorySupplier" alignment="BASELINE_LEFT" graphicTextGap="12.0" maxWidth="Infinity"
                          mnemonicParsing="false" onAction="#handleNavInventorySupplier" prefHeight="40.0"
                          style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;"
                          text="Inventory &amp; Suppliers">
                     <graphic>
                        <StackPane minWidth="20.0" minHeight="20.0" mouseTransparent="true">
                           <children>
                              <SVGPath content="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"
                                        fill="TRANSPARENT" stroke="#374151" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                           </children>
                        </StackPane>
                     </graphic>
                  </Button>
                  <Button fx:id="btnAiInsights" alignment="BASELINE_LEFT" graphicTextGap="12.0" maxWidth="Infinity"
                          mnemonicParsing="false" onAction="#handleNavAiInsights" prefHeight="40.0"
                          style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;"
                          text="AI Insights">
                     <graphic>
                        <StackPane minWidth="20.0" minHeight="20.0" mouseTransparent="true">
                           <children>
                              <SVGPath content="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
                                        fill="TRANSPARENT" stroke="#374151" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                           </children>
                        </StackPane>
                     </graphic>
                  </Button>
               </children>
            </VBox>

            <!-- 4. FinanceInvoices -->
            <Button fx:id="btnInvoices"
                    alignment="BASELINE_LEFT" graphicTextGap="12.0" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleNavInvoices" prefHeight="45.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-cursor: hand;"
                    text="FinanceInvoices">
               <graphic>
                  <StackPane minWidth="24.0" minHeight="24.0" mouseTransparent="true">
                     <children>
                        <SVGPath content="M7 3h10a2 2 0 012 2v14a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2zm2 4h6M9 11h6M9 15h4"
                                 fill="TRANSPARENT" stroke="#374151" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                     </children>
                  </StackPane>
               </graphic>
               <font><Font size="14.0" /></font>
            </Button>

            <!-- NOTE: "Support & Alerts" REMOVED — notifications accessed via bell icon in FinanceTopBar -->

            <!-- 5. Audit Log -->
            <Button fx:id="btnAuditLog"
                    alignment="BASELINE_LEFT" graphicTextGap="12.0" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleNavAuditLog" prefHeight="45.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-cursor: hand;"
                    text="Audit Log">
               <graphic>
                  <StackPane minWidth="24.0" minHeight="24.0" mouseTransparent="true">
                     <children>
                        <SVGPath content="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                 fill="TRANSPARENT" stroke="#374151" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                     </children>
                  </StackPane>
               </graphic>
               <font><Font size="14.0" /></font>
            </Button>

            <!-- 6. FinanceSettings -->
            <Button fx:id="btnSettings"
                    alignment="BASELINE_LEFT" graphicTextGap="12.0" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleNavSettings" prefHeight="45.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #374151; -fx-background-radius: 8; -fx-cursor: hand;"
                    text="FinanceSettings">
               <graphic>
                  <StackPane minWidth="24.0" minHeight="24.0" mouseTransparent="true">
                     <children>
                        <SVGPath content="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"
                                 fill="TRANSPARENT" stroke="#374151" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
                     </children>
                  </StackPane>
               </graphic>
               <font><Font size="14.0" /></font>
            </Button>

         </children>
      </VBox>

      <!-- FOOTER: version + logout -->
      <VBox style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0;">
         <padding><Insets bottom="16.0" left="12.0" right="12.0" top="16.0" /></padding>
         <children>
            <VBox style="-fx-background-color: #F9FAFB; -fx-background-radius: 8;">
               <padding><Insets bottom="8.0" left="16.0" right="16.0" top="8.0" /></padding>
               <VBox.margin><Insets bottom="12.0" /></VBox.margin>
               <children>
                  <Label text="System Version" textFill="#4B5563"><font><Font size="11.0" /></font></Label>
                  <Label text="v2.4.1" textFill="#9CA3AF"><font><Font size="11.0" /></font></Label>
               </children>
            </VBox>

            <Button fx:id="btnLogout"
                    alignment="CENTER" graphicTextGap="8.0" maxWidth="Infinity"
                    mnemonicParsing="false" onAction="#handleLogout" prefHeight="40.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #4B5563; -fx-cursor: hand; -fx-background-radius: 8;"
                    text="Logout">
               <graphic>
                  <SVGPath content="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4 M16 17l5-5-5-5 M21 12H9"
                           fill="TRANSPARENT" stroke="#4B5563" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeWidth="1.5" />
               </graphic>
               <font><Font size="14.0" /></font>
            </Button>
         </children>
      </VBox>

   </children>
</VBox>
