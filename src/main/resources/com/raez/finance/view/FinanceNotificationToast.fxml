<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.paint.Color?>

<!--
  Toast notification widget.
  Controller calls setNotification(type, title, message, callback) to configure.
  Slide-in / auto-dismiss / slide-out is handled entirely in the controller.
-->
<HBox
    fx:id="rootBox"
    alignment="CENTER_LEFT"
    minWidth="200"
    maxWidth="360"
    spacing="0"
    style="-fx-background-color: white; -fx-border-color: #E5E7EB;
           -fx-border-radius: 8; -fx-background-radius: 8;"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.raez.finance.controller.FinanceNotificationToastController">

    <effect>
        <DropShadow blurType="GAUSSIAN" radius="18" spread="0.02" offsetY="4">
            <color><Color opacity="0.14" /></color>
        </DropShadow>
    </effect>

    <!-- Coloured left accent bar — colour set in controller -->
    <Rectangle fx:id="accentBar"
               width="4" arcWidth="4" arcHeight="4"
               style="-fx-fill: #2563EB;" />

    <HBox alignment="CENTER_LEFT" spacing="10" HBox.hgrow="ALWAYS">
        <padding><Insets top="8" right="10" bottom="8" left="10" /></padding>

        <!-- Icon -->
        <StackPane minWidth="28" minHeight="28"
                   style="-fx-background-radius: 999;"
                   fx:id="iconWrapper">
            <SVGPath fx:id="iconPath"
                     fill="TRANSPARENT"
                     stroke="#2563EB"
                     strokeLineCap="ROUND"
                     strokeLineJoin="ROUND"
                     strokeWidth="2"
                     content="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z M12 16v-4 M12 8h.01" />
        </StackPane>

        <!-- Text block -->
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTitle" text="Notification"
                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #111827;" />
            <Label fx:id="lblMessage" text=""
                   wrapText="true"
                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" />
        </VBox>

        <!-- Close button -->
        <Button fx:id="btnClose"
                onAction="#handleClose"
                style="-fx-background-color: transparent; -fx-cursor: hand;
                       -fx-border-color: transparent; -fx-padding: 4 4 4 4;">
            <graphic>
                <SVGPath content="M18 6L6 18 M6 6l12 12"
                         fill="TRANSPARENT"
                         stroke="#9CA3AF"
                         strokeLineCap="ROUND"
                         strokeLineJoin="ROUND"
                         strokeWidth="2" />
            </graphic>
        </Button>
    </HBox>

</HBox>
