<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.raez.controllers.CustomerAdminDashboardController"
            style="-fx-background-color: white;">

    <top>
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="15" right="30" bottom="15" left="30"/></padding>
            <VBox spacing="2">
                <Label text="RAEZ" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                <Label text="Staff Dashboard" style="-fx-text-fill: #6B7280; -fx-font-size: 12px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-border-color: #D1D5DB; -fx-padding: 8 16;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
            <content>
                <VBox spacing="20" style="-fx-background-color: white;">
                    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

                    <!-- Analytics Cards -->
                    <HBox spacing="15">
                        <VBox spacing="5" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-padding: 20;">
                            <Label text="Total Customers" style="-fx-text-fill: #6B7280;"/>
                            <Label fx:id="totalCustomersLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-padding: 20;">
                            <Label text="Total Revenue" style="-fx-text-fill: #6B7280;"/>
                            <Label fx:id="totalRevenueLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-padding: 20;">
                            <Label text="Active Accounts" style="-fx-text-fill: #6B7280;"/>
                            <Label fx:id="activeAccountsLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-padding: 20;">
                            <Label text="Deactivated Accounts" style="-fx-text-fill: #6B7280;"/>
                            <Label fx:id="deactivatedAccountsLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                        </VBox>
                    </HBox>

                    <!-- Search and Filter -->
                    <HBox spacing="15" alignment="CENTER_LEFT"
                          style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-padding: 20;">
                        <TextField fx:id="searchField"
                                   promptText="Search by name, email, or customer ID"
                                   HBox.hgrow="ALWAYS"/>
                        <ComboBox fx:id="statusFilter" prefWidth="160"/>
                        <Button text="Search" onAction="#handleSearch"
                                style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-padding: 8 16;"/>
                    </HBox>

                    <!-- Customer Table -->
                    <VBox spacing="10"
                          style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-padding: 20;">
                        <Label fx:id="noResultsLabel"
                               text="No customers found matching your search criteria"
                               style="-fx-text-fill: #6B7280;" visible="false" managed="false"/>
                        <TableView fx:id="customersTable" prefHeight="400">
                            <columns>
                                <TableColumn fx:id="colName"   text="Name"           prefWidth="180"/>
                                <TableColumn fx:id="colEmail"  text="Email"          prefWidth="200"/>
                                <TableColumn fx:id="colStatus" text="Account Status" prefWidth="130"/>
                                <TableColumn fx:id="colSpent"  text="Total Spent"    prefWidth="120"/>
                                <TableColumn fx:id="colAction" text="Actions"        prefWidth="120"/>
                            </columns>
                        </TableView>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
