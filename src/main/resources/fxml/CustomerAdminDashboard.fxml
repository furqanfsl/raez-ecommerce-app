<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.raez.controllers.CustomerAdminDashboardController"
            styleClass="admin-shell"
            style="-fx-background-color: #F5F7FA;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="admin-topbar">
            <VBox spacing="0">
                <Label text="RAEZ Customer Admin" styleClass="admin-topbar-title" />
                <Label text="Staff Dashboard" styleClass="admin-topbar-subtitle" />
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🏬  Storefront" onAction="#handleGoToStorefront"
                    styleClass="admin-chip-white" />
            <Button text="🚪  Logout" onAction="#handleLogout"
                    styleClass="admin-chip-white" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <content>
                <VBox spacing="20">
                    <padding><Insets top="28" right="32" bottom="28" left="32"/></padding>

                    <!-- Analytics Cards -->
                    <HBox spacing="16">
                        <VBox spacing="5" HBox.hgrow="ALWAYS" styleClass="admin-metric">
                            <Label text="Total Customers" styleClass="admin-metric-label" />
                            <Label fx:id="totalCustomersLabel" styleClass="admin-metric-value" />
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS" styleClass="admin-metric">
                            <Label text="Total Revenue" styleClass="admin-metric-label" />
                            <Label fx:id="totalRevenueLabel"
                                   style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #10B981;" />
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS" styleClass="admin-metric">
                            <Label text="Active Accounts" styleClass="admin-metric-label" />
                            <Label fx:id="activeAccountsLabel" styleClass="admin-metric-value" />
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS" styleClass="admin-metric">
                            <Label text="Deactivated Accounts" styleClass="admin-metric-label" />
                            <Label fx:id="deactivatedAccountsLabel"
                                   style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #EF4444;" />
                        </VBox>
                    </HBox>

                    <!-- Search and Filter -->
                    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="admin-section">
                        <TextField fx:id="searchField"
                                   promptText="Search by name, email, or customer ID"
                                   styleClass="admin-input"
                                   HBox.hgrow="ALWAYS"/>
                        <ComboBox fx:id="statusFilter" prefWidth="160"/>
                        <Button text="Search" onAction="#handleSearch" styleClass="admin-btn-primary" />
                    </HBox>

                    <!-- Customer Table -->
                    <VBox spacing="10" styleClass="admin-section">
                        <Label text="Customer Directory" styleClass="admin-section-title" />
                        <Label fx:id="noResultsLabel"
                               text="No customers found matching your search criteria"
                               style="-fx-text-fill: #6B7280;" visible="false" managed="false"/>
                        <TableView fx:id="customersTable" prefHeight="400" styleClass="admin-table">
                            <columns>
                                <TableColumn fx:id="colName"   text="Name"           prefWidth="180"/>
                                <TableColumn fx:id="colEmail"  text="Email"          prefWidth="200"/>
                                <TableColumn fx:id="colStatus" text="Account Status" prefWidth="130"/>
                                <TableColumn fx:id="colSpent"  text="Total Spent"    prefWidth="120"/>
                                <TableColumn fx:id="colAction" text="Actions"        prefWidth="120"/>
                            </columns>
                        </TableView>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
