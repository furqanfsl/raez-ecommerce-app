<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.raez.controllers.ProductAdminDashboardController"
      styleClass="admin-shell"
      style="-fx-background-color: #F5F7FA;">

    <!-- Admin top bar: brand gradient with white chips, matches SuperAdmin -->
    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="admin-topbar">
        <Label text="RAEZ Product Admin" styleClass="admin-topbar-title" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="⬅  Back to Home" onAction="#handleBackToHome"
                styleClass="admin-btn-ghost" />
        <Button text="🏬  Storefront" onAction="#handleGoToStorefront"
                styleClass="admin-chip-white" />
    </HBox>

    <!-- Top header -->
    <VBox styleClass="admin-page-header">
        <HBox alignment="CENTER_LEFT">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Product Management" styleClass="admin-page-title" />
                <Label text="Manage your RAEZ product catalog — add, edit, and organize futuristic robots"
                       styleClass="admin-page-subtitle" />
            </VBox>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Import" onAction="#handleImport" styleClass="admin-btn-secondary" />
                <Button text="Export" onAction="#handleExport" styleClass="admin-btn-secondary" />
                <Button text="+ Add Product" onAction="#handleAddProduct" styleClass="admin-btn-primary" />
            </HBox>
        </HBox>
    </VBox>

    <!-- Main content -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: #F5F7FA; -fx-border-color: transparent;">
        <content>
            <HBox style="-fx-padding: 32 40 32 40;" spacing="24" alignment="TOP_LEFT">

                <!-- Left sidebar -->
                <VBox spacing="16" prefWidth="280" minWidth="280">
                    <fx:include fx:id="productFilters" source="ProductFilters.fxml" />

                    <!-- Stats -->
                    <VBox styleClass="admin-section" spacing="12">
                        <Label text="Statistics" styleClass="admin-section-title" />
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Total Products" style="-fx-font-size: 13; -fx-text-fill: #6B7280;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="statTotal" text="0"
                                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #0891B2;" />
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Active" style="-fx-font-size: 13; -fx-text-fill: #6B7280;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="statActive" text="0"
                                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #10B981;" />
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Inactive" style="-fx-font-size: 13; -fx-text-fill: #6B7280;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="statInactive" text="0"
                                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #6B7280;" />
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Out of Stock" style="-fx-font-size: 13; -fx-text-fill: #6B7280;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="statOutOfStock" text="0"
                                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #EF4444;" />
                        </HBox>
                    </VBox>
                </VBox>

                <!-- Right: toolbar + table -->
                <VBox spacing="16" HBox.hgrow="ALWAYS">
                    <HBox styleClass="admin-section" alignment="CENTER_LEFT">
                        <Label fx:id="showingLabel" text="Showing 0 of 0 products"
                               style="-fx-font-size: 13; -fx-text-fill: #6B7280;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox spacing="8" alignment="CENTER_RIGHT">
                            <Label text="Sort by:" style="-fx-font-size: 13; -fx-text-fill: #6B7280;" />
                            <MenuButton fx:id="sortMenuBtn" text="Recently Updated"
                                        styleClass="admin-btn-secondary">
                                <items>
                                    <MenuItem text="Recently Updated"  onAction="#handleSortUpdated"  />
                                    <MenuItem text="Name (A-Z)"        onAction="#handleSortNameAsc"  />
                                    <MenuItem text="Name (Z-A)"        onAction="#handleSortNameDesc" />
                                    <MenuItem text="Price Low to High" onAction="#handleSortPriceAsc" />
                                    <MenuItem text="Price High to Low" onAction="#handleSortPriceDesc"/>
                                    <MenuItem text="Stock Low to High" onAction="#handleSortStockAsc" />
                                </items>
                            </MenuButton>
                        </HBox>
                    </HBox>

                    <fx:include fx:id="productTable" source="ProductTable.fxml" />
                </VBox>
            </HBox>
        </content>
    </ScrollPane>
</VBox>
