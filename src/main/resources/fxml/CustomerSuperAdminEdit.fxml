<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.raez.controllers.CustomerSuperAdminEditController"
            style="-fx-background-color: white;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="15" right="30" bottom="15" left="30"/></padding>
            <Button text="← Back to Dashboard" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-border-color: #D1D5DB; -fx-padding: 8 16; -fx-cursor: hand;"/>
            <VBox spacing="2">
                <Label text="RAEZ Super Admin" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Label text="Full Edit Access"
                       style="-fx-text-fill: #7C3AED; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-border-color: #D1D5DB; -fx-padding: 8 16; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
            <content>
                <VBox spacing="20" style="-fx-background-color: white;">
                    <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

                    <!-- Customer Info Card -->
                    <VBox spacing="10"
                          style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-padding: 20;">
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label fx:id="customerNameLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                                <Label fx:id="customerIdLabel" style="-fx-text-fill: #6B7280;"/>
                                <Label fx:id="customerSpentLabel" style="-fx-text-fill: #6B7280;"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="4">
                                <Label text="Account Status" style="-fx-text-fill: #6B7280; -fx-font-size: 11px;"/>
                                <Label fx:id="customerStatusLabel" style="-fx-font-weight: bold;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Tabs -->
                    <HBox spacing="0">
                        <Button fx:id="tabProfile" text="Profile"
                                onAction="#handleTabProfile"
                                style="-fx-background-color: #7C3AED; -fx-text-fill: white; -fx-padding: 8 20; -fx-cursor: hand;"/>
                        <Button fx:id="tabPreferences" text="Preferences"
                                onAction="#handleTabPreferences"
                                style="-fx-background-color: transparent; -fx-border-color: #E5E7EB; -fx-padding: 8 20; -fx-cursor: hand;"/>
                        <Button fx:id="tabOrders" text="Order History"
                                onAction="#handleTabOrders"
                                style="-fx-background-color: transparent; -fx-border-color: #E5E7EB; -fx-padding: 8 20; -fx-cursor: hand;"/>
                    </HBox>

                    <StackPane>

                        <!-- PROFILE TAB -->
                        <VBox fx:id="profilePane" spacing="12" visible="true" managed="true"
                              style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-padding: 20;">
                            <Label fx:id="profileMessageLabel" wrapText="true"/>
                            <HBox spacing="15">
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="First Name"/>
                                    <TextField fx:id="firstNameField" promptText="Enter first name"/>
                                </VBox>
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="Last Name"/>
                                    <TextField fx:id="lastNameField" promptText="Enter last name"/>
                                </VBox>
                            </HBox>
                            <VBox spacing="5">
                                <Label text="Email Address (Super Admin Can Edit)"
                                       style="-fx-font-weight: bold; -fx-text-fill: #7C3AED;"/>
                                <TextField fx:id="emailField" promptText="Enter email"/>
                                <Label fx:id="emailErrorLabel"
                                       style="-fx-text-fill: red; -fx-font-size: 11px;" wrapText="true"/>
                            </VBox>
                            <VBox spacing="5">
                                <Label text="Contact Number"/>
                                <TextField fx:id="phoneField" promptText="Enter phone"/>
                                <Label fx:id="phoneErrorLabel" style="-fx-text-fill: red; -fx-font-size: 11px;"/>
                            </VBox>
                            <VBox spacing="5">
                                <Label text="Delivery Address"/>
                                <TextArea fx:id="addressField" prefRowCount="3" wrapText="true"/>
                            </VBox>
                            <VBox spacing="8">
                                <Label text="ID Card Image (Super Admin Can Edit)"
                                       style="-fx-font-weight: bold; -fx-text-fill: #7C3AED;"/>
                                <HBox style="-fx-background-color: #F3F4F6; -fx-border-color: #D1D5DB; -fx-border-radius: 6; -fx-padding: 12;">
                                    <Label fx:id="idCardLabel" style="-fx-text-fill: #6B7280;"/>
                                </HBox>
                                <Button text="Change Image"
                                        onAction="#handleChangeImage"
                                        style="-fx-background-color: #7C3AED; -fx-text-fill: white; -fx-padding: 8 16; -fx-cursor: hand;"/>
                            </VBox>
                            <HBox spacing="10">
                                <Button text="Save Changes"
                                        onAction="#handleSaveProfile"
                                        style="-fx-background-color: #7C3AED; -fx-text-fill: white; -fx-padding: 10 20; -fx-cursor: hand;"/>
                                <Button fx:id="toggleStatusBtn"
                                        onAction="#handleToggleStatus"
                                        style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-padding: 10 20; -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>

                        <!-- PREFERENCES TAB -->
                        <VBox fx:id="preferencesPane" spacing="12" visible="false" managed="false"
                              style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-padding: 20;">
                            <Label fx:id="preferencesMessageLabel" style="-fx-text-fill: green;" wrapText="true"/>
                            <Label text="Robot Categories of Interest" style="-fx-text-fill: #374151;"/>
                            <FlowPane fx:id="categoriesPane" hgap="10" vgap="10"/>
                            <Label text="Notification Preferences"/>
                            <ComboBox fx:id="notificationsCombo" prefWidth="300"/>
                            <Label text="Delivery Instructions"/>
                            <TextArea fx:id="deliveryInstructionsField"
                                      prefRowCount="3" wrapText="true"
                                      promptText="Special delivery instructions..."/>
                            <Button text="Save Preferences"
                                    onAction="#handleSavePreferences"
                                    style="-fx-background-color: #7C3AED; -fx-text-fill: white; -fx-padding: 10 20; -fx-cursor: hand;"/>
                        </VBox>

                        <!-- ORDER HISTORY TAB -->
                        <VBox fx:id="ordersPane" spacing="12" visible="false" managed="false"
                              style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-padding: 20;">
                            <Label text="Data shown from RAEZ Orders Module"
                                   style="-fx-text-fill: #6B7280; -fx-font-size: 12px;"/>
                            <TableView fx:id="ordersTable" prefHeight="300">
                                <columns>
                                    <TableColumn fx:id="colOrderId"   text="Order ID"   prefWidth="100"/>
                                    <TableColumn fx:id="colRobotType" text="Robot Type" prefWidth="150"/>
                                    <TableColumn fx:id="colDate"      text="Date"       prefWidth="120"/>
                                    <TableColumn fx:id="colStatus"    text="Status"     prefWidth="120"/>
                                    <TableColumn fx:id="colAmount"    text="Amount"     prefWidth="100"/>
                                </columns>
                            </TableView>
                        </VBox>

                    </StackPane>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
