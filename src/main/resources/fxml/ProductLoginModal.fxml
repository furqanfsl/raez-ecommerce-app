<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Hyperlink?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.raez.controllers.ProductLoginModalController"
      prefWidth="440"
      style="-fx-background-color: white; -fx-border-color: #e5e7eb;
             -fx-border-radius: 8; -fx-background-radius: 8;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 16, 0.2, 0, 4);">

    <!-- Header -->
    <VBox style="-fx-background-color: #000080; -fx-padding: 24 24 20 24;
                 -fx-background-radius: 8 8 0 0;">
        <HBox alignment="CENTER_LEFT">
            <Label text="Welcome to RAEZ"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="✕" onAction="#handleClose"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                           -fx-font-size: 16; -fx-text-fill: white; -fx-cursor: hand;" />
        </HBox>
        <Label text="Customer sign-in"
               style="-fx-font-size: 13; -fx-text-fill: #cbd5e1; -fx-padding: 4 0 0 0;" />
    </VBox>

    <VBox style="-fx-padding: 24;" spacing="16">

        <!-- Email -->
        <VBox spacing="6">
            <Label text="Email" style="-fx-font-size: 13; -fx-text-fill: #374151;" />
            <TextField fx:id="emailField"
                       promptText="your@email.com"
                       style="-fx-font-size: 14; -fx-padding: 10 14 10 14;
                              -fx-border-color: #d1d5db; -fx-border-radius: 8;
                              -fx-background-radius: 8; -fx-background-color: white;" />
        </VBox>

        <!-- Password -->
        <VBox spacing="6">
            <Label text="Password" style="-fx-font-size: 13; -fx-text-fill: #374151;" />
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           style="-fx-font-size: 14; -fx-padding: 10 14 10 14;
                                  -fx-border-color: #d1d5db; -fx-border-radius: 8;
                                  -fx-background-radius: 8; -fx-background-color: white;" />
        </VBox>

        <!-- Error -->
        <Label fx:id="errorLabel" text=""
               visible="false" managed="false"
               style="-fx-font-size: 12; -fx-text-fill: #dc2626;" />

        <!-- Submit -->
        <Button fx:id="submitBtn" text="Sign In"
                onAction="#handleLogin"
                maxWidth="Infinity"
                style="-fx-background-color: #000080; -fx-text-fill: white;
                       -fx-font-size: 14; -fx-font-weight: bold;
                       -fx-padding: 12 0 12 0; -fx-background-radius: 8;
                       -fx-cursor: hand; -fx-border-color: transparent;" />

        <!-- Quick actions -->
        <HBox alignment="CENTER" spacing="14">
            <Hyperlink text="Demo customer login" onAction="#handleFillDemo"
                       style="-fx-font-size: 12; -fx-text-fill: #000080; -fx-border-color: transparent;" />
            <Label text="•" style="-fx-font-size: 12; -fx-text-fill: #9ca3af;" />
            <Hyperlink text="Forgot password?" onAction="#handleForgotPassword"
                       style="-fx-font-size: 12; -fx-text-fill: #000080; -fx-border-color: transparent;" />
        </HBox>

        <!-- Register -->
        <HBox alignment="CENTER" spacing="4" fx:id="registerRow"
              style="-fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0; -fx-padding: 14 0 0 0;">
            <Label text="New to RAEZ?" style="-fx-font-size: 13; -fx-text-fill: #6b7280;" />
            <Hyperlink text="Create an account" onAction="#handleCreateAccount"
                       style="-fx-font-size: 13; -fx-text-fill: #000080; -fx-border-color: transparent;" />
        </HBox>
    </VBox>
</VBox>
