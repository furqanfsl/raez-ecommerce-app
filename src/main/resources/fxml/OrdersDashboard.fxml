<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.raez.orders.controller.OrdersDashboardController"
            styleClass="admin-shell"
            style="-fx-background-color: #F5F7FA;">

    <top>
        <HBox spacing="14" alignment="CENTER_LEFT" styleClass="admin-topbar">
            <Label text="RAEZ Order Management" styleClass="admin-topbar-title" />
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="statsLabel"
                   style="-fx-font-size:13;-fx-text-fill:rgba(255,255,255,0.72);"/>
            <Button text="🚪  Logout" onAction="#handleLogout"
                    styleClass="admin-btn-danger" />
        </HBox>
    </top>

    <center>
        <VBox spacing="16">
            <padding><Insets top="24" right="32" bottom="24" left="32"/></padding>

            <!-- Filter bar -->
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="admin-section">
                <TextField fx:id="searchField" promptText="Search by customer or order ID..."
                           prefWidth="320" prefHeight="36"
                           styleClass="admin-input"/>
                <ComboBox fx:id="statusFilter" prefWidth="180" prefHeight="36"/>
                <Button text="Refresh" onAction="#handleRefresh" styleClass="admin-btn-primary" />
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="countLabel" style="-fx-font-size:13;-fx-text-fill:#6B7280;"/>
            </HBox>

            <!-- Orders table -->
            <VBox styleClass="admin-section" VBox.vgrow="ALWAYS" spacing="8">
                <Label text="Orders" styleClass="admin-section-title" />
                <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS" styleClass="admin-table">
                    <columns>
                        <TableColumn fx:id="idCol"       text="Order ID"    prefWidth="90"/>
                        <TableColumn fx:id="customerCol" text="Customer"    prefWidth="200"/>
                        <TableColumn fx:id="dateCol"     text="Order Date"  prefWidth="180"/>
                        <TableColumn fx:id="totalCol"    text="Total (£)"   prefWidth="120"/>
                        <TableColumn fx:id="itemsCol"    text="Items"       prefWidth="80"/>
                        <TableColumn fx:id="statusCol"   text="Status"      prefWidth="140"/>
                        <TableColumn fx:id="actionsCol"  text="Actions"     prefWidth="240"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
