<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.raez.controllers.ProductHeaderController"
      spacing="0" maxWidth="Infinity" minWidth="0"
      style="-fx-background-color: white;">

    <!-- Row 1: Logo / Search / Icons -->
    <HBox prefHeight="64" alignment="CENTER_LEFT" maxWidth="Infinity" minWidth="0"
          style="-fx-background-color: white; -fx-border-color: #e5e7eb;
                 -fx-border-width: 0 0 1 0; -fx-padding: 0 32 0 32;">

        <Button fx:id="logoBtn" text="RAEZ"
                onAction="#handleLogoClick"
                style="-fx-background-color: transparent; -fx-border-color: transparent;
                       -fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1E2939;
                       -fx-cursor: hand; -fx-padding: 0; -fx-letter-spacing: 2;" />

        <Region minWidth="24" HBox.hgrow="ALWAYS" />

        <TextField fx:id="searchField"
                   promptText="Search robots, collections, accessories..."
                   prefHeight="40" maxWidth="520" HBox.hgrow="ALWAYS"
                   style="-fx-background-color: #f9fafb; -fx-border-color: #e5e7eb;
                          -fx-border-radius: 8; -fx-background-radius: 8;
                          -fx-padding: 0 16 0 16; -fx-font-size: 13;
                          -fx-prompt-text-fill: #9ca3af;" />

        <Region minWidth="24" HBox.hgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT" spacing="22">

            <!-- Favourites -->
            <StackPane>
                <Button fx:id="heartBtn" text="♡"
                        onAction="#handleHeartClick"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;
                               -fx-font-size: 22; -fx-text-fill: #1E2939; -fx-cursor: hand;
                               -fx-padding: 0;" />
                <Label fx:id="heartBadge" text="0"
                       visible="false" managed="false"
                       StackPane.alignment="TOP_RIGHT"
                       style="-fx-background-color: #ef4444; -fx-text-fill: white;
                              -fx-font-size: 10; -fx-font-weight: bold;
                              -fx-background-radius: 10; -fx-padding: 1 5 1 5;
                              -fx-translate-x: 10; -fx-translate-y: -8;" />
            </StackPane>

            <!-- Cart -->
            <StackPane>
                <Button text="&#128722;" onAction="#handleCartClick"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;
                               -fx-font-size: 20; -fx-text-fill: #1E2939; -fx-cursor: hand;
                               -fx-padding: 0;" />
                <Label fx:id="cartBadge" text="0"
                       StackPane.alignment="TOP_RIGHT"
                       style="-fx-background-color: #1E2939; -fx-text-fill: white;
                              -fx-font-size: 10; -fx-font-weight: bold;
                              -fx-background-radius: 10; -fx-padding: 1 5 1 5;
                              -fx-translate-x: 10; -fx-translate-y: -8;" />
            </StackPane>

            <!-- Profile menu -->
            <MenuButton fx:id="userMenuBtn" text="&#128100;"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;
                               -fx-font-size: 20; -fx-text-fill: #1E2939; -fx-cursor: hand;
                               -fx-padding: 0;">
                <items>
                    <MenuItem fx:id="loginMenuItem"         text="Sign In"         onAction="#handleOpenLogin" />
                    <MenuItem fx:id="manageAccountMenuItem" text="My Account"      onAction="#handleManageAccount"
                              visible="false" />
                    <MenuItem fx:id="myReviewsMenuItem"     text="My Reviews"      onAction="#handleMyReviews"
                              visible="false" />
                    <SeparatorMenuItem fx:id="logoutSeparator" visible="false" />
                    <MenuItem fx:id="logoutMenuItem"        text="Logout"          onAction="#handleLogout"
                              visible="false" />
                </items>
            </MenuButton>

            <!-- Admin shortcut (visible to admin roles only) -->
            <Button fx:id="adminBtn" text="&#9881;"
                    onAction="#handleNavigateAdmin"
                    visible="false" managed="false"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                           -fx-font-size: 18; -fx-cursor: hand;" />
        </HBox>
    </HBox>

    <!-- Row 2: Primary Navigation -->
    <HBox alignment="CENTER" spacing="38" prefHeight="44" maxWidth="Infinity" minWidth="0"
          style="-fx-background-color: white; -fx-border-color: #e5e7eb;
                 -fx-border-width: 0 0 1 0;">

        <MenuButton fx:id="collectionsMenu" text="Collections  ▾"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                           -fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1E2939;
                           -fx-cursor: hand; -fx-padding: 0;">
            <items>
                <MenuItem text="Apex Automata — Kinetic Series"       onAction="#handleCollectionApexAutomata" />
                <MenuItem text="Sentinel Force — Guardian Series"     onAction="#handleCollectionSentinelForce" />
                <MenuItem text="NovaMind — Intelligence Series"       onAction="#handleCollectionNovaMind" />
                <MenuItem text="TerraCore — Industrial Series"        onAction="#handleCollectionTerraCore" />
                <SeparatorMenuItem />
                <MenuItem text="View All Collections"                 onAction="#handleFilterAll" />
            </items>
        </MenuButton>

        <Button text="Robots" onAction="#handleNavRobots"
                style="-fx-background-color: transparent; -fx-border-color: transparent;
                       -fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1E2939;
                       -fx-cursor: hand; -fx-padding: 0;" />

        <Button text="Mini Robots" onAction="#handleNavMiniRobots"
                style="-fx-background-color: transparent; -fx-border-color: transparent;
                       -fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1E2939;
                       -fx-cursor: hand; -fx-padding: 0;" />

        <Button text="Accessories" onAction="#handleNavAccessories"
                style="-fx-background-color: transparent; -fx-border-color: transparent;
                       -fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1E2939;
                       -fx-cursor: hand; -fx-padding: 0;" />

        <Button text="Services" onAction="#handleNavServices"
                style="-fx-background-color: transparent; -fx-border-color: transparent;
                       -fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1E2939;
                       -fx-cursor: hand; -fx-padding: 0;" />

    </HBox>
</VBox>
