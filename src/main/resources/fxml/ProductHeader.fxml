<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Label?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.ProductHeaderController"
      prefHeight="64"
      alignment="CENTER_LEFT"
      style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0; -fx-padding: 0 32 0 32;">

    <Button fx:id="logoBtn" text="RAEZ"
            onAction="#handleLogoClick"
            style="-fx-background-color: transparent; -fx-border-color: transparent;
                   -fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #111827;
                   -fx-cursor: hand; -fx-padding: 0;" />

    <Region HBox.hgrow="ALWAYS" />

    <HBox alignment="CENTER" prefWidth="460">
        <TextField fx:id="searchField"
                   promptText="Search..."
                   prefWidth="460" prefHeight="38"
                   style="-fx-background-color: white;
                          -fx-border-color: #e5e7eb;
                          -fx-border-radius: 8; -fx-background-radius: 8;
                          -fx-padding: 0 16 0 40;
                          -fx-font-size: 14; -fx-prompt-text-fill: #9ca3af;" />
    </HBox>

    <Region HBox.hgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="20">

        <MenuButton fx:id="menuBtn" text="Menu"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                           -fx-font-size: 14; -fx-text-fill: #374151; -fx-cursor: hand;
                           -fx-padding: 0;">
            <items>
                <MenuItem text="Shop"            onAction="#handleNavigateHome" />
                <MenuItem text="New Arrivals"    onAction="#handleNavigateHome" />
                <MenuItem text="Home Assistants" onAction="#handleNavigateHome" />
                <MenuItem text="Security Bots"   onAction="#handleNavigateHome" />
                <MenuItem text="Educational"     onAction="#handleNavigateHome" />
                <MenuItem text="Companions"      onAction="#handleNavigateHome" />
                <MenuItem text="Sale"            onAction="#handleNavigateHome" />
            </items>
        </MenuButton>

        <StackPane>
            <Button fx:id="heartBtn" text="♡"
                    onAction="#handleHeartClick"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                           -fx-font-size: 22; -fx-text-fill: #374151; -fx-cursor: hand;
                           -fx-padding: 0;" />
            <Label fx:id="heartBadge" text="0"
                   visible="false" managed="false"
                   StackPane.alignment="TOP_RIGHT"
                   style="-fx-background-color: #ef4444; -fx-text-fill: white;
                          -fx-font-size: 10; -fx-font-weight: bold;
                          -fx-background-radius: 10; -fx-padding: 1 5 1 5;
                          -fx-translate-x: 10; -fx-translate-y: -8;" />
        </StackPane>

        <StackPane>
            <Button text="&#128722;"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                           -fx-font-size: 20; -fx-text-fill: #374151; -fx-cursor: hand; -fx-padding: 0;" />
            <Label fx:id="cartBadge" text="0"
                   StackPane.alignment="TOP_RIGHT"
                   style="-fx-background-color: #111827; -fx-text-fill: white;
                          -fx-font-size: 10; -fx-font-weight: bold;
                          -fx-background-radius: 10; -fx-padding: 1 5 1 5;
                          -fx-translate-x: 10; -fx-translate-y: -8;" />
        </StackPane>

        <MenuButton fx:id="userMenuBtn" text="&#128100;"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                           -fx-font-size: 20; -fx-text-fill: #374151; -fx-cursor: hand; -fx-padding: 0;">
            <items>
                <MenuItem fx:id="loginMenuItem"  text="Login"  onAction="#handleOpenLogin" />
                <MenuItem fx:id="logoutMenuItem" text="Logout" onAction="#handleLogout" />
            </items>
        </MenuButton>

        <Button fx:id="adminBtn" text="&#9881;"
                onAction="#handleNavigateAdmin"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-border-color: transparent;
                       -fx-font-size: 18; -fx-cursor: hand;" />
    </HBox>
</HBox>
