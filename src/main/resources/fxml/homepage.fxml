<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.ScrollPane?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.HomepageController"
            style="-fx-background-color: white;">

    <top>
        <fx:include source="Header.fxml" />
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: white; -fx-border-color: transparent;">
            <content>
                <VBox spacing="0">

                    <!-- HERO: full width, no sidebar beside it -->
                    <fx:include source="NewHomePage.fxml" />

                    <!-- SHOP SECTION: sidebar + product grid -->
                    <HBox spacing="0" style="-fx-background-color: white;">
                        <fx:include fx:id="sidebar" source="Sidebar.fxml" />
                        <fx:include fx:id="productList" source="ProductList.fxml" />
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
