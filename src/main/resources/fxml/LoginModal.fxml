<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Hyperlink?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.LoginModalController"
      prefWidth="440"
      style="-fx-background-color: white; -fx-border-color: #e5e7eb;
             -fx-border-radius: 8; -fx-background-radius: 8;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 16, 0.2, 0, 4);">

    <!-- Header -->
    <VBox style="-fx-background-color: #f9fafb; -fx-padding: 24 24 20 24;
                 -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;
                 -fx-background-radius: 8 8 0 0;">
        <HBox alignment="CENTER_LEFT">
            <Label text="Login to RAEZ"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #111827;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="✕" onAction="#handleClose"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                           -fx-font-size: 16; -fx-text-fill: #9ca3af; -fx-cursor: hand;" />
        </HBox>
        <Label text="Access your account"
               style="-fx-font-size: 13; -fx-text-fill: #6b7280; -fx-padding: 4 0 0 0;" />
    </VBox>

    <!-- Tabs: Customer / Admin -->
    <HBox style="-fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
        <Button fx:id="customerTabBtn" text="Customer Login"
                onAction="#handleCustomerTab"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                style="-fx-background-color: #f9fafb; -fx-border-color: transparent transparent #111827 transparent;
                       -fx-border-width: 0 0 2 0; -fx-font-size: 14; -fx-text-fill: #111827;
                       -fx-padding: 14 0 14 0; -fx-cursor: hand; -fx-background-radius: 0;" />
        <Button fx:id="adminTabBtn" text="Admin Login"
                onAction="#handleAdminTab"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                style="-fx-background-color: white; -fx-border-color: transparent;
                       -fx-font-size: 14; -fx-text-fill: #6b7280;
                       -fx-padding: 14 0 14 0; -fx-cursor: hand; -fx-background-radius: 0;" />
    </HBox>

    <!-- Form body -->
    <VBox style="-fx-padding: 24;" spacing="20">

        <!-- Demo credentials box -->
        <VBox style="-fx-background-color: #eff6ff; -fx-border-color: #bfdbfe;
                     -fx-border-radius: 8; -fx-background-radius: 8;
                     -fx-padding: 14;" spacing="4">
            <Label text="Demo Credentials:"
                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;" />
            <Label fx:id="demoEmailLabel" text="Email: customer@example.com"
                   style="-fx-font-size: 12; -fx-text-fill: #4b5563;" />
            <Label fx:id="demoPasswordLabel" text="Password: customer123"
                   style="-fx-font-size: 12; -fx-text-fill: #4b5563;" />
            <Hyperlink text="Fill demo credentials" onAction="#handleFillDemo"
                       style="-fx-font-size: 12; -fx-text-fill: #2563eb; -fx-padding: 2 0 0 0;" />
        </VBox>

        <!-- Email -->
        <VBox spacing="6">
            <HBox spacing="4">
                <Label text="Email"
                       style="-fx-font-size: 13; -fx-text-fill: #374151;" />
                <Label fx:id="adminEmailHint" text="(@raez required)"
                       visible="false" managed="false"
                       style="-fx-font-size: 13; -fx-text-fill: #2563eb;" />
            </HBox>
            <TextField fx:id="emailField"
                       promptText="your@email.com"
                       style="-fx-font-size: 14; -fx-padding: 10 14 10 14;
                              -fx-border-color: #d1d5db; -fx-border-radius: 8;
                              -fx-background-radius: 8; -fx-background-color: white;" />
        </VBox>

        <!-- Password -->
        <VBox spacing="6">
            <Label text="Password" style="-fx-font-size: 13; -fx-text-fill: #374151;" />
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           style="-fx-font-size: 14; -fx-padding: 10 14 10 14;
                                  -fx-border-color: #d1d5db; -fx-border-radius: 8;
                                  -fx-background-radius: 8; -fx-background-color: white;" />
        </VBox>

        <!-- Error message -->
        <Label fx:id="errorLabel" text=""
               visible="false" managed="false"
               style="-fx-font-size: 12; -fx-text-fill: #dc2626;" />

        <!-- Submit button -->
        <Button fx:id="submitBtn" text="Login as Customer"
                onAction="#handleLogin"
                maxWidth="Infinity"
                style="-fx-background-color: #111827; -fx-text-fill: white;
                       -fx-font-size: 14; -fx-font-weight: bold;
                       -fx-padding: 12 0 12 0; -fx-background-radius: 8;
                       -fx-cursor: hand; -fx-border-color: transparent;" />
    </VBox>
</VBox>
