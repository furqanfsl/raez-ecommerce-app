<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.raez.controllers.SuperAdminDashboardController"
            prefWidth="1280" prefHeight="800"
            styleClass="admin-shell"
            style="-fx-background-color: #F5F7FA;">

    <!-- Top navigation bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              styleClass="admin-topbar">
            <Label text="RAEZ Super Admin" styleClass="admin-topbar-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="welcomeLabel"
                   style="-fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.72);" />
            <Button text="🏬  Storefront" onAction="#handleGoToStorefront"
                    styleClass="admin-chip-white" />
            <Button text="🚪  Logout" onAction="#handleLogout"
                    styleClass="admin-chip-white" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox spacing="24" style="-fx-padding: 28 32 28 32;">

                    <!-- Metric tiles -->
                    <HBox spacing="16">
                        <VBox fx:id="tileActiveUsers" spacing="6" HBox.hgrow="ALWAYS"
                              styleClass="admin-metric">
                            <Label text="Active Users" styleClass="admin-metric-label" />
                            <Label fx:id="activeUsersValue" text="0" styleClass="admin-metric-value" />
                            <Label text="Staff &amp; admin accounts" styleClass="admin-metric-caption" />
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS" styleClass="admin-metric">
                            <Label text="Active Customers" styleClass="admin-metric-label" />
                            <Label fx:id="activeCustomersValue" text="0"
                                   style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #10B981;" />
                            <Label text="Registered storefront accounts" styleClass="admin-metric-caption" />
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS" styleClass="admin-metric">
                            <Label text="Active Products" styleClass="admin-metric-label" />
                            <Label fx:id="productCountValue" text="0" styleClass="admin-metric-value" />
                            <Label text="Published catalogue" styleClass="admin-metric-caption" />
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS" styleClass="admin-metric">
                            <Label text="Total Orders" styleClass="admin-metric-label" />
                            <Label fx:id="orderCountValue" text="0"
                                   style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #F59E0B;" />
                            <Label text="Lifetime placed" styleClass="admin-metric-caption" />
                        </VBox>
                    </HBox>

                    <!-- Module navigation grid -->
                    <VBox spacing="12" styleClass="admin-section">
                        <Label text="Module Command Center" styleClass="admin-section-title" />
                        <Label text="Open any admin workspace directly from here."
                               style="-fx-font-size: 12; -fx-text-fill: #6B7280;" />
                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                            </columnConstraints>
                            <Button text="Products"   onAction="#openProducts"
                                    maxWidth="Infinity" prefHeight="60"
                                    styleClass="admin-btn-primary"
                                    GridPane.rowIndex="0" GridPane.columnIndex="0" />
                            <Button text="Customers"  onAction="#openCustomers"
                                    maxWidth="Infinity" prefHeight="60"
                                    styleClass="admin-btn-primary"
                                    GridPane.rowIndex="0" GridPane.columnIndex="1" />
                            <Button text="Orders"     onAction="#openOrders"
                                    maxWidth="Infinity" prefHeight="60"
                                    styleClass="admin-btn-primary"
                                    GridPane.rowIndex="0" GridPane.columnIndex="2" />
                            <Button text="Warehouse"  onAction="#openWarehouse"
                                    maxWidth="Infinity" prefHeight="60"
                                    styleClass="admin-btn-primary"
                                    GridPane.rowIndex="0" GridPane.columnIndex="3" />
                            <Button text="Deliveries" onAction="#openDeliveries"
                                    maxWidth="Infinity" prefHeight="60"
                                    styleClass="admin-btn-primary"
                                    GridPane.rowIndex="1" GridPane.columnIndex="0" />
                            <Button text="Finance"    onAction="#openFinance"
                                    maxWidth="Infinity" prefHeight="60"
                                    styleClass="admin-btn-primary"
                                    GridPane.rowIndex="1" GridPane.columnIndex="1" />
                            <Button text="Reviews"    onAction="#openReviews"
                                    maxWidth="Infinity" prefHeight="60"
                                    styleClass="admin-btn-primary"
                                    GridPane.rowIndex="1" GridPane.columnIndex="2" />
                            <Button text="Storefront" onAction="#openStorefront"
                                    maxWidth="Infinity" prefHeight="60"
                                    styleClass="admin-btn-secondary"
                                    GridPane.rowIndex="1" GridPane.columnIndex="3" />
                        </GridPane>
                    </VBox>

                    <!-- User management + SMTP side-by-side -->
                    <HBox spacing="18">
                        <!-- Users -->
                        <VBox spacing="12" HBox.hgrow="ALWAYS" styleClass="admin-section">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="User Management" styleClass="admin-section-title" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button text="+ New User" onAction="#handleAddUser"
                                        styleClass="admin-btn-primary" />
                                <Button text="Refresh" onAction="#handleRefresh"
                                        styleClass="admin-btn-secondary" />
                            </HBox>

                            <TableView fx:id="userTable" prefHeight="300" styleClass="admin-table">
                                <columns>
                                    <TableColumn fx:id="colId"       text="ID"        prefWidth="50" />
                                    <TableColumn fx:id="colName"     text="Name"      prefWidth="150" />
                                    <TableColumn fx:id="colEmail"    text="Email"     prefWidth="210" />
                                    <TableColumn fx:id="colRole"     text="Role"      prefWidth="130" />
                                    <TableColumn fx:id="colActive"   text="Active"    prefWidth="60" />
                                    <TableColumn fx:id="colLastLogin" text="Last Login" prefWidth="140" />
                                </columns>
                            </TableView>
                            <HBox spacing="8">
                                <Button text="✏  Edit Selected" onAction="#handleEditUser"
                                        styleClass="admin-btn-primary" />
                                <Button text="⇄  Toggle Active" onAction="#handleToggleActive"
                                        styleClass="admin-btn-secondary" />
                                <Button text="🗑  Delete" onAction="#handleDeleteUser"
                                        styleClass="admin-btn-danger" />
                            </HBox>
                        </VBox>

                        <!-- SMTP -->
                        <VBox spacing="10" prefWidth="380" styleClass="admin-section">
                            <Label text="SMTP Settings" styleClass="admin-section-title" />
                            <Label text="Used for password recovery and notifications."
                                   style="-fx-font-size: 11; -fx-text-fill: #6B7280;" />

                            <Label text="SMTP Host" styleClass="admin-field-label">
                                <padding><Insets top="6" /></padding>
                            </Label>
                            <TextField fx:id="smtpHostField" promptText="smtp.gmail.com" styleClass="admin-input" />

                            <Label text="Port" styleClass="admin-field-label">
                                <padding><Insets top="6" /></padding>
                            </Label>
                            <TextField fx:id="smtpPortField" promptText="587" styleClass="admin-input" />

                            <Label text="Username" styleClass="admin-field-label">
                                <padding><Insets top="6" /></padding>
                            </Label>
                            <TextField fx:id="smtpUsernameField" promptText="account@gmail.com" styleClass="admin-input" />

                            <Label text="Password / App Password" styleClass="admin-field-label">
                                <padding><Insets top="6" /></padding>
                            </Label>
                            <PasswordField fx:id="smtpPasswordField" promptText="••••••••" styleClass="admin-input" />

                            <Label text="From Address" styleClass="admin-field-label">
                                <padding><Insets top="6" /></padding>
                            </Label>
                            <TextField fx:id="smtpFromField" promptText="no-reply@raez.org.uk" styleClass="admin-input" />

                            <CheckBox fx:id="smtpTlsBox" text="Use TLS" selected="true" />
                            <CheckBox fx:id="smtpEnabledBox" text="Enable email sending" />

                            <Label fx:id="smtpStatusLabel" text=""
                                   style="-fx-font-size: 11; -fx-text-fill: #10B981;" wrapText="true" />

                            <HBox spacing="8">
                                <Button text="Save SMTP Settings" onAction="#handleSaveSmtp"
                                        maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                        styleClass="admin-btn-primary" />
                            </HBox>
                        </VBox>
                    </HBox>
                    <!-- Demo Credentials Reference -->
                    <VBox spacing="10" styleClass="admin-alert-card">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="🔑  Demo Login Credentials" styleClass="admin-alert-title" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="Password for all demo accounts: raez123"
                                   style="-fx-font-size: 12; -fx-text-fill: #78350F;
                                          -fx-background-color: #FEF3C7; -fx-padding: 4 10;
                                          -fx-background-radius: 999;" />
                        </HBox>
                        <Label text="Use these credentials to log in as any role for testing:"
                               style="-fx-font-size: 12; -fx-text-fill: #92400E;" />
                        <TableView fx:id="credentialsTable" prefHeight="220" styleClass="admin-table"
                                   style="-fx-background-color: transparent;">
                            <columns>
                                <TableColumn fx:id="credRoleCol"  text="Role"       prefWidth="150" />
                                <TableColumn fx:id="credNameCol"  text="Name"       prefWidth="180" />
                                <TableColumn fx:id="credEmailCol" text="Email"      prefWidth="260" />
                                <TableColumn fx:id="credPwdCol"   text="Password"   prefWidth="120" />
                            </columns>
                        </TableView>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
