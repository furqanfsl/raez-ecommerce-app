<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Hyperlink?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.raez.controllers.AdminLoginModalController"
      prefWidth="520"
      style="-fx-background-color: white; -fx-border-color: #e5e7eb;
             -fx-border-radius: 8; -fx-background-radius: 8;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 16, 0.2, 0, 4);">

    <!-- Header -->
    <VBox style="-fx-background-color: #000080; -fx-padding: 24 24 20 24;
                 -fx-background-radius: 8 8 0 0;">
        <HBox alignment="CENTER_LEFT">
            <Label text="RAEZ Admin Portal"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="✕" onAction="#handleClose"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                           -fx-font-size: 16; -fx-text-fill: white; -fx-cursor: hand;" />
        </HBox>
        <Label text="Restricted access — staff only"
               style="-fx-font-size: 13; -fx-text-fill: #cbd5e1; -fx-padding: 4 0 0 0;" />
    </VBox>

    <VBox style="-fx-padding: 24;" spacing="16">

        <!-- Email -->
        <VBox spacing="6">
            <Label text="Admin Email" style="-fx-font-size: 13; -fx-text-fill: #374151;" />
            <TextField fx:id="emailField"
                       promptText="your.admin@raez.org.uk"
                       style="-fx-font-size: 14; -fx-padding: 10 14 10 14;
                              -fx-border-color: #d1d5db; -fx-border-radius: 8;
                              -fx-background-radius: 8; -fx-background-color: white;" />
        </VBox>

        <!-- Password -->
        <VBox spacing="6">
            <Label text="Password" style="-fx-font-size: 13; -fx-text-fill: #374151;" />
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           style="-fx-font-size: 14; -fx-padding: 10 14 10 14;
                                  -fx-border-color: #d1d5db; -fx-border-radius: 8;
                                  -fx-background-radius: 8; -fx-background-color: white;" />
        </VBox>

        <Label fx:id="errorLabel" text=""
               visible="false" managed="false"
               style="-fx-font-size: 12; -fx-text-fill: #dc2626;" />

        <Button fx:id="submitBtn" text="Sign In"
                onAction="#handleLogin"
                maxWidth="Infinity"
                style="-fx-background-color: #000080; -fx-text-fill: white;
                       -fx-font-size: 14; -fx-font-weight: bold;
                       -fx-padding: 12 0 12 0; -fx-background-radius: 8;
                       -fx-cursor: hand; -fx-border-color: transparent;" />

        <HBox alignment="CENTER">
            <Hyperlink text="Forgot password?" onAction="#handleForgotPassword"
                       style="-fx-font-size: 12; -fx-text-fill: #000080; -fx-border-color: transparent;" />
        </HBox>

        <!-- Demo quick-fill grid -->
        <VBox spacing="6" style="-fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0; -fx-padding: 14 0 0 0;">
            <Label text="Demo Logins (for testing)"
                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #374151;" />
            <GridPane hgap="8" vgap="8">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                </columnConstraints>
                <Button text="Super"     onAction="#demoSuperAdmin"
                        maxWidth="Infinity"
                        style="-fx-background-color: #000080; -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"
                        GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <Button text="Products"  onAction="#demoProduct"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1e3a8a; -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"
                        GridPane.rowIndex="0" GridPane.columnIndex="1" />
                <Button text="Customers" onAction="#demoCustomerAdmin"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1e3a8a; -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"
                        GridPane.rowIndex="0" GridPane.columnIndex="2" />
                <Button text="Orders"    onAction="#demoOrders"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1e3a8a; -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"
                        GridPane.rowIndex="0" GridPane.columnIndex="3" />
                <Button text="Warehouse" onAction="#demoWarehouse"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1e3a8a; -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"
                        GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <Button text="Delivery"  onAction="#demoDelivery"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1e3a8a; -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"
                        GridPane.rowIndex="1" GridPane.columnIndex="1" />
                <Button text="Finance"   onAction="#demoFinance"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1e3a8a; -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"
                        GridPane.rowIndex="1" GridPane.columnIndex="2" />
                <Button text="Reviews"   onAction="#demoReviews"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1e3a8a; -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"
                        GridPane.rowIndex="1" GridPane.columnIndex="3" />
            </GridPane>
        </VBox>
    </VBox>
</VBox>
