<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.raez.controllers.AdminLoginModalController"
           prefWidth="560" prefHeight="780">

    <!-- Base gradient mesh: deep blue → teal → violet (matches customer login/hero) -->
    <Pane style="-fx-background-color: linear-gradient(to bottom right, #0a0f1f 0%, #0d2538 35%, #1a3347 60%, #2a1a4a 100%);
                 -fx-background-radius: 24;"
          maxWidth="Infinity" maxHeight="Infinity" />

    <!-- Mesh blob: teal glow, top-left -->
    <Pane style="-fx-background-color: radial-gradient(center 15% 20%, radius 45%, rgba(20,184,166,0.30) 0%, transparent 70%);
                 -fx-background-radius: 24;"
          maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true" />

    <!-- Mesh blob: violet glow, bottom-right -->
    <Pane style="-fx-background-color: radial-gradient(center 80% 75%, radius 50%, rgba(139,92,246,0.28) 0%, transparent 70%);
                 -fx-background-radius: 24;"
          maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true" />

    <!-- Scrollable so the card stays visible on short screens -->
    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <content>
            <VBox alignment="TOP_CENTER" spacing="0" fillWidth="true"
                  style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="28" right="24" bottom="28" left="24" />
                </padding>


                <!-- Dark Card -->
                <StackPane maxWidth="460">

                    <!-- Dark solid background -->
                    <Pane style="-fx-background-color: #0d1520;
                                 -fx-background-radius: 24;
                                 -fx-border-color: rgba(255,255,255,0.12);
                                 -fx-border-radius: 24; -fx-border-width: 0.5;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 40, 0.3, 0, 16);" />

                    <VBox spacing="0" style="-fx-padding: 0;">

                        <!-- Header -->
                        <VBox spacing="6" style="-fx-padding: 28 34 20 34;">
                            <Label text="STAFF PORTAL"
                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                          -fx-font-size: 10; -fx-font-weight: bold;
                                          -fx-text-fill: #5eead4; -fx-letter-spacing: 3;" />
                            <Label text="Sign in to RAEZ Admin"
                                   style="-fx-font-family: 'Inter','Segoe UI','Montserrat',sans-serif;
                                          -fx-font-size: 24; -fx-font-weight: 900;
                                          -fx-text-fill: white;" />
                            <Label text="Restricted access — admin, warehouse, finance &amp; ops"
                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                          -fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.65);" />
                        </VBox>

                        <!-- Form -->
                        <VBox spacing="14" style="-fx-padding: 0 34 24 34;">

                            <!-- Email -->
                            <VBox spacing="7">
                                <Label text="Admin Email"
                                       style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                              -fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);
                                              -fx-letter-spacing: 1;" />
                                <TextField fx:id="emailField"
                                           promptText="your.admin@raez.org.uk"
                                           maxWidth="Infinity"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 14; -fx-padding: 14 16 14 16;
                                                  -fx-text-fill: white;
                                                  -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                  -fx-background-color: rgba(255,255,255,0.06);
                                                  -fx-background-radius: 14;
                                                  -fx-border-color: rgba(255,255,255,0.18);
                                                  -fx-border-radius: 14; -fx-border-width: 0.5;" />
                            </VBox>

                            <!-- Password -->
                            <VBox spacing="7">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Password"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);
                                                  -fx-letter-spacing: 1;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Hyperlink text="Forgot password?" onAction="#handleForgotPassword"
                                               style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                      -fx-font-size: 12; -fx-text-fill: #5eead4;
                                                      -fx-border-color: transparent;" />
                                </HBox>
                                <PasswordField fx:id="passwordField"
                                               promptText="Enter your password"
                                               maxWidth="Infinity"
                                               style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                      -fx-font-size: 14; -fx-padding: 14 16 14 16;
                                                      -fx-text-fill: white;
                                                      -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                      -fx-background-color: rgba(255,255,255,0.06);
                                                      -fx-background-radius: 14;
                                                      -fx-border-color: rgba(255,255,255,0.18);
                                                      -fx-border-radius: 14; -fx-border-width: 0.5;" />
                            </VBox>

                            <!-- General error -->
                            <Label fx:id="errorLabel" text=""
                                   visible="false" managed="false"
                                   style="-fx-text-fill: #fca5a5; -fx-font-size: 12;"
                                   wrapText="true" />

                            <!-- Admin Login — bright liquid button (sole functional difference from Customer) -->
                            <Button fx:id="submitBtn" text="Admin Login →"
                                    onAction="#handleLogin"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: rgba(255,255,255,0.95);
                                           -fx-text-fill: #0a0f1f;
                                           -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                           -fx-font-size: 14; -fx-font-weight: bold;
                                           -fx-padding: 14 0 14 0;
                                           -fx-background-radius: 20;
                                           -fx-border-color: rgba(255,255,255,0.6);
                                           -fx-border-radius: 20; -fx-border-width: 0.5;
                                           -fx-cursor: hand;
                                           -fx-effect: dropshadow(gaussian, rgba(94,234,212,0.4), 14, 0.25, 0, 4);" />

                        </VBox>

                        <!-- Demo quick-fill grid (kept for testing, styled to match dark theme) -->
                        <VBox spacing="10" style="-fx-padding: 0 34 28 34;">
                            <Label text="Demo Logins (for testing)"
                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                          -fx-font-size: 11; -fx-font-weight: bold;
                                          -fx-text-fill: rgba(255,255,255,0.7);
                                          -fx-letter-spacing: 1;" />
                            <GridPane hgap="8" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="25" />
                                    <ColumnConstraints percentWidth="25" />
                                    <ColumnConstraints percentWidth="25" />
                                    <ColumnConstraints percentWidth="25" />
                                </columnConstraints>
                                <Button text="Super"     onAction="#demoSuperAdmin"   maxWidth="Infinity"
                                        style="-fx-background-color: rgba(94,234,212,0.18); -fx-text-fill: #5eead4; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 8 0; -fx-border-color: rgba(94,234,212,0.35); -fx-border-radius: 12; -fx-border-width: 0.5;"
                                        GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                <Button text="Products"  onAction="#demoProduct"      maxWidth="Infinity"
                                        style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 8 0; -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 12; -fx-border-width: 0.5;"
                                        GridPane.rowIndex="0" GridPane.columnIndex="1" />
                                <Button text="Customers" onAction="#demoCustomerAdmin" maxWidth="Infinity"
                                        style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 8 0; -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 12; -fx-border-width: 0.5;"
                                        GridPane.rowIndex="0" GridPane.columnIndex="2" />
                                <Button text="Orders"    onAction="#demoOrders"       maxWidth="Infinity"
                                        style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 8 0; -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 12; -fx-border-width: 0.5;"
                                        GridPane.rowIndex="0" GridPane.columnIndex="3" />
                                <Button text="Warehouse" onAction="#demoWarehouse"    maxWidth="Infinity"
                                        style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 8 0; -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 12; -fx-border-width: 0.5;"
                                        GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                <Button text="Delivery"  onAction="#demoDelivery"     maxWidth="Infinity"
                                        style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 8 0; -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 12; -fx-border-width: 0.5;"
                                        GridPane.rowIndex="1" GridPane.columnIndex="1" />
                                <Button text="Finance"   onAction="#demoFinance"      maxWidth="Infinity"
                                        style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 8 0; -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 12; -fx-border-width: 0.5;"
                                        GridPane.rowIndex="1" GridPane.columnIndex="2" />
                                <Button text="Reviews"   onAction="#demoReviews"      maxWidth="Infinity"
                                        style="-fx-background-color: rgba(255,255,255,0.06); -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-padding: 8 0; -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 12; -fx-border-width: 0.5;"
                                        GridPane.rowIndex="1" GridPane.columnIndex="3" />
                            </GridPane>
                        </VBox>

                    </VBox>
                </StackPane>

            </VBox>
        </content>
    </ScrollPane>

    <!-- Pinned close button — last child so it sits on top of the ScrollPane.
         Sized 44×44 with translate offsets, always reachable in the corner. -->
    <Button text="✕" onAction="#handleClose"
            StackPane.alignment="TOP_RIGHT"
            style="-fx-background-color: rgba(255,255,255,0.10);
                   -fx-border-color: rgba(255,255,255,0.30); -fx-border-radius: 22;
                   -fx-border-width: 0.5; -fx-background-radius: 22;
                   -fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;
                   -fx-cursor: hand;
                   -fx-min-width: 44; -fx-min-height: 44;
                   -fx-max-width: 44; -fx-max-height: 44;
                   -fx-padding: 0;
                   -fx-translate-x: -18; -fx-translate-y: 18;
                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 10, 0.2, 0, 3);" />
</StackPane>
