<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.raez.controllers.ProductListController"
      style="-fx-background-color: #080d16; -fx-padding: 24 32 24 32;"
      spacing="16" maxWidth="Infinity" minWidth="0"
      HBox.hgrow="ALWAYS">

    <!-- Breadcrumb -->
    <HBox spacing="6" alignment="CENTER_LEFT">
        <Label text="SHOP" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.35);
                                 -fx-font-family: 'Inter','Segoe UI',sans-serif; -fx-letter-spacing: 2;" />
        <Label text="/"    style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.20);" />
        <Label fx:id="breadcrumbLabel" text="All Products"
               style="-fx-font-size: 11; -fx-text-fill: #5eead4;
                      -fx-font-family: 'Inter','Segoe UI',sans-serif; -fx-letter-spacing: 2;" />
    </HBox>

    <!-- Title + sort -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="2">
            <Label fx:id="titleLabel" text="All Products"
                   style="-fx-font-size: 28; -fx-font-weight: 900; -fx-text-fill: white;
                          -fx-font-family: 'Inter','Segoe UI','Montserrat',sans-serif;" />
            <Label fx:id="itemCountLabel" text="0 items"
                   style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.55);
                          -fx-font-family: 'Inter','Segoe UI',sans-serif;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER_RIGHT" spacing="8">
            <Label text="Sort:" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.55);
                                       -fx-font-family: 'Inter','Segoe UI',sans-serif;" />
            <MenuButton fx:id="sortButton" text="Recommended"
                        style="-fx-background-color: rgba(255,255,255,0.06);
                               -fx-border-color: rgba(255,255,255,0.18);
                               -fx-border-radius: 20; -fx-background-radius: 20; -fx-border-width: 0.5;
                               -fx-text-fill: white; -fx-font-family: 'Inter','Segoe UI',sans-serif;
                               -fx-font-size: 12; -fx-padding: 6 14 6 14;">
                <items>
                    <MenuItem text="Recommended"        onAction="#handleSortRecommended" />
                    <MenuItem text="Price: Low to High" onAction="#handleSortPriceAsc" />
                    <MenuItem text="Price: High to Low" onAction="#handleSortPriceDesc" />
                    <MenuItem text="Name: A–Z"          onAction="#handleSortName" />
                    <MenuItem text="Newest"             onAction="#handleSortNewest" />
                </items>
            </MenuButton>
        </HBox>
    </HBox>

    <!-- Product grid built dynamically in ProductListController -->
    <VBox fx:id="productContainer" spacing="0" />

</VBox>
