<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.ProductFiltersController"
      style="-fx-background-color: white; -fx-border-color: #e5e7eb;
             -fx-border-radius: 8; -fx-background-radius: 8;
             -fx-padding: 20;" spacing="16">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT">
        <Label text="Filters"
               style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #111827;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="clearBtn" text="✕ Clear all"
                onAction="#handleClearFilters"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-border-color: transparent;
                       -fx-font-size: 12; -fx-text-fill: #6b7280; -fx-cursor: hand;" />
    </HBox>

    <!-- Search -->
    <VBox spacing="6">
        <Label text="Search by name"
               style="-fx-font-size: 12; -fx-text-fill: #374151;" />
        <TextField fx:id="searchField"
                   promptText="Search products..."
                   onKeyReleased="#handleSearchChange"
                   style="-fx-font-size: 13; -fx-padding: 8 12 8 12;
                          -fx-border-color: #d1d5db; -fx-border-radius: 6;
                          -fx-background-radius: 6;" />
    </VBox>

    <!-- Category -->
    <VBox spacing="6">
        <Label text="Category" style="-fx-font-size: 12; -fx-text-fill: #374151;" />
        <MenuButton fx:id="categoryBtn" text="All categories"
                    maxWidth="Infinity"
                    style="-fx-background-color: white; -fx-border-color: #d1d5db;
                           -fx-border-radius: 6; -fx-background-radius: 6;
                           -fx-font-size: 13; -fx-padding: 8 12 8 12;">
            <items>
                <MenuItem text="All categories"    onAction="#handleCategoryChange" />
                <MenuItem text="Home Assistants"   onAction="#handleCategoryChange" />
                <MenuItem text="Security Bots"     onAction="#handleCategoryChange" />
                <MenuItem text="Educational"       onAction="#handleCategoryChange" />
                <MenuItem text="Companions"        onAction="#handleCategoryChange" />
                <MenuItem text="Industrial"        onAction="#handleCategoryChange" />
            </items>
        </MenuButton>
    </VBox>

    <!-- Price Range -->
    <VBox spacing="6">
        <Label text="Price Range (£)" style="-fx-font-size: 12; -fx-text-fill: #374151;" />
        <HBox spacing="8">
            <TextField fx:id="minPriceField" promptText="Min"
                       onKeyReleased="#handlePriceChange"
                       prefWidth="110"
                       style="-fx-font-size: 13; -fx-padding: 8 10 8 10;
                              -fx-border-color: #d1d5db; -fx-border-radius: 6;
                              -fx-background-radius: 6;" />
            <Label text="—" style="-fx-text-fill: #9ca3af;" />
            <TextField fx:id="maxPriceField" promptText="Max"
                       onKeyReleased="#handlePriceChange"
                       prefWidth="110"
                       style="-fx-font-size: 13; -fx-padding: 8 10 8 10;
                              -fx-border-color: #d1d5db; -fx-border-radius: 6;
                              -fx-background-radius: 6;" />
        </HBox>
    </VBox>

    <!-- Status -->
    <VBox spacing="6">
        <Label text="Availability Status" style="-fx-font-size: 12; -fx-text-fill: #374151;" />
        <MenuButton fx:id="statusBtn" text="All statuses"
                    maxWidth="Infinity"
                    style="-fx-background-color: white; -fx-border-color: #d1d5db;
                           -fx-border-radius: 6; -fx-background-radius: 6;
                           -fx-font-size: 13; -fx-padding: 8 12 8 12;">
            <items>
                <MenuItem text="All statuses" onAction="#handleStatusChange" />
                <MenuItem text="Active"       onAction="#handleStatusChange" />
                <MenuItem text="Inactive"     onAction="#handleStatusChange" />
            </items>
        </MenuButton>
    </VBox>

</VBox>
