<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.raez.controllers.CustomerDashboardController">

    <!-- Gradient mesh background — same family as login + hero -->
    <Pane style="-fx-background-color: linear-gradient(to bottom right, #0a0f1f 0%, #0d2538 35%, #1a3347 60%, #2a1a4a 100%);"
          maxWidth="Infinity" maxHeight="Infinity" />
    <Pane style="-fx-background-color: radial-gradient(center 15% 20%, radius 45%, rgba(20,184,166,0.20) 0%, transparent 70%);"
          maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true" />
    <Pane style="-fx-background-color: radial-gradient(center 80% 75%, radius 50%, rgba(139,92,246,0.20) 0%, transparent 70%);"
          maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true" />

    <BorderPane>

        <!-- ── Top bar: brand + back-to-store + logout ───────────────────── -->
        <top>
            <HBox alignment="CENTER_LEFT" spacing="14"
                  style="-fx-background-color: rgba(10,15,31,0.82);
                         -fx-border-color: rgba(255,255,255,0.10);
                         -fx-border-width: 0 0 0.5 0;">
                <padding><Insets top="14" right="32" bottom="14" left="32"/></padding>

                <Label text="RAEZ"
                       style="-fx-font-family: 'Inter','Segoe UI','Montserrat',sans-serif;
                              -fx-font-size: 22; -fx-font-weight: 900; -fx-text-fill: white;
                              -fx-letter-spacing: 2;
                              -fx-effect: dropshadow(gaussian, rgba(94,234,212,0.35), 10, 0.25, 0, 0);" />
                <Label text="·  My Account"
                       style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                              -fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.55);
                              -fx-letter-spacing: 1;" />

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="←  Back to storefront" onAction="#handleBackToStore"
                        style="-fx-background-color: rgba(94,234,212,0.16);
                               -fx-text-fill: #5eead4;
                               -fx-font-family: 'Inter','Segoe UI',sans-serif;
                               -fx-font-size: 12; -fx-font-weight: bold;
                               -fx-padding: 9 18 9 18;
                               -fx-background-radius: 22;
                               -fx-border-color: rgba(94,234,212,0.35);
                               -fx-border-radius: 22; -fx-border-width: 0.5;
                               -fx-cursor: hand;" />

                <Button text="Logout" onAction="#handleLogout"
                        style="-fx-background-color: rgba(255,255,255,0.06);
                               -fx-text-fill: white;
                               -fx-font-family: 'Inter','Segoe UI',sans-serif;
                               -fx-font-size: 12; -fx-font-weight: bold;
                               -fx-padding: 9 18 9 18;
                               -fx-background-radius: 22;
                               -fx-border-color: rgba(255,255,255,0.25);
                               -fx-border-radius: 22; -fx-border-width: 0.5;
                               -fx-cursor: hand;" />
            </HBox>
        </top>

        <!-- ── Main content ──────────────────────────────────────────────── -->
        <center>
            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <content>
                    <VBox spacing="22" style="-fx-background-color: transparent;">
                        <padding><Insets top="32" right="44" bottom="44" left="44"/></padding>

                        <!-- Welcome / Identity card -->
                        <StackPane>
                            <Pane style="-fx-background-color: rgba(13,21,32,0.78);
                                         -fx-background-radius: 22;
                                         -fx-border-color: rgba(255,255,255,0.10);
                                         -fx-border-radius: 22; -fx-border-width: 0.5;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 22, 0.25, 0, 8);" />
                            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 26 30 26 30;">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label text="WELCOME BACK"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 10; -fx-font-weight: bold;
                                                  -fx-text-fill: #5eead4; -fx-letter-spacing: 3;" />
                                    <Label fx:id="customerNameLabel"
                                           style="-fx-font-family: 'Inter','Segoe UI','Montserrat',sans-serif;
                                                  -fx-font-size: 26; -fx-font-weight: 900; -fx-text-fill: white;" />
                                    <Label fx:id="customerIdLabel"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.55);" />
                                </VBox>
                                <VBox alignment="CENTER" spacing="6">
                                    <Label text="ACCOUNT STATUS"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 10; -fx-font-weight: bold;
                                                  -fx-text-fill: rgba(255,255,255,0.55);
                                                  -fx-letter-spacing: 2;"/>
                                    <Label fx:id="customerStatusLabel"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 12; -fx-font-weight: bold;
                                                  -fx-padding: 6 16; -fx-background-radius: 20;"/>
                                </VBox>
                            </HBox>
                        </StackPane>

                        <!-- Main glass card with tabs -->
                        <StackPane>
                            <Pane style="-fx-background-color: rgba(13,21,32,0.78);
                                         -fx-background-radius: 22;
                                         -fx-border-color: rgba(255,255,255,0.10);
                                         -fx-border-radius: 22; -fx-border-width: 0.5;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 22, 0.25, 0, 8);" />

                            <VBox spacing="18" style="-fx-padding: 26 30 30 30;">

                                <Label text="My Account"
                                       style="-fx-font-family: 'Inter','Segoe UI','Montserrat',sans-serif;
                                              -fx-font-size: 19; -fx-font-weight: 900; -fx-text-fill: white;" />

                                <!-- Tab pills -->
                                <HBox spacing="10">
                                    <Button fx:id="tabProfile" text="Profile"
                                            onAction="#handleTabProfile"
                                            style="-fx-background-color: rgba(94,234,212,0.18);
                                                   -fx-text-fill: #5eead4;
                                                   -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                   -fx-font-size: 12; -fx-font-weight: bold;
                                                   -fx-padding: 9 20; -fx-background-radius: 22;
                                                   -fx-border-color: rgba(94,234,212,0.35);
                                                   -fx-border-radius: 22; -fx-border-width: 0.5;
                                                   -fx-cursor: hand;"/>
                                    <Button fx:id="tabPreferences" text="Preferences"
                                            onAction="#handleTabPreferences"
                                            style="-fx-background-color: rgba(255,255,255,0.06);
                                                   -fx-text-fill: rgba(255,255,255,0.75);
                                                   -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                   -fx-font-size: 12; -fx-font-weight: bold;
                                                   -fx-padding: 9 20; -fx-background-radius: 22;
                                                   -fx-border-color: rgba(255,255,255,0.18);
                                                   -fx-border-radius: 22; -fx-border-width: 0.5;
                                                   -fx-cursor: hand;"/>
                                    <Button fx:id="tabOrders" text="Order history"
                                            onAction="#handleTabOrders"
                                            style="-fx-background-color: rgba(255,255,255,0.06);
                                                   -fx-text-fill: rgba(255,255,255,0.75);
                                                   -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                   -fx-font-size: 12; -fx-font-weight: bold;
                                                   -fx-padding: 9 20; -fx-background-radius: 22;
                                                   -fx-border-color: rgba(255,255,255,0.18);
                                                   -fx-border-radius: 22; -fx-border-width: 0.5;
                                                   -fx-cursor: hand;"/>
                                    <Button fx:id="tabEligible" text="My reviews"
                                            onAction="#handleTabEligible"
                                            style="-fx-background-color: rgba(255,255,255,0.06);
                                                   -fx-text-fill: rgba(255,255,255,0.75);
                                                   -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                   -fx-font-size: 12; -fx-font-weight: bold;
                                                   -fx-padding: 9 20; -fx-background-radius: 22;
                                                   -fx-border-color: rgba(255,255,255,0.18);
                                                   -fx-border-radius: 22; -fx-border-width: 0.5;
                                                   -fx-cursor: hand;"/>
                                </HBox>

                                <StackPane fx:id="tabContent">

                                    <!-- PROFILE TAB -->
                                    <VBox fx:id="profilePane" spacing="14" visible="true" managed="true">
                                        <Label fx:id="profileMessageLabel" wrapText="true"
                                               style="-fx-text-fill: #5eead4; -fx-font-size: 12;"/>

                                        <Label text="First name"
                                               style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.65);
                                                      -fx-letter-spacing: 1;"/>
                                        <TextField fx:id="firstNameField" promptText="Enter your first name"
                                                   style="-fx-font-size: 13; -fx-padding: 12 14 12 14;
                                                          -fx-text-fill: white;
                                                          -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                          -fx-background-color: rgba(255,255,255,0.06);
                                                          -fx-background-radius: 12;
                                                          -fx-border-color: rgba(255,255,255,0.18);
                                                          -fx-border-radius: 12; -fx-border-width: 0.5;"/>

                                        <Label text="Last name"
                                               style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.65);
                                                      -fx-letter-spacing: 1;"/>
                                        <TextField fx:id="lastNameField" promptText="Enter your last name"
                                                   style="-fx-font-size: 13; -fx-padding: 12 14 12 14;
                                                          -fx-text-fill: white;
                                                          -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                          -fx-background-color: rgba(255,255,255,0.06);
                                                          -fx-background-radius: 12;
                                                          -fx-border-color: rgba(255,255,255,0.18);
                                                          -fx-border-radius: 12; -fx-border-width: 0.5;"/>

                                        <Label text="Email address"
                                               style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.65);
                                                      -fx-letter-spacing: 1;"/>
                                        <TextField fx:id="emailField" editable="false"
                                                   style="-fx-font-size: 13; -fx-padding: 12 14 12 14;
                                                          -fx-text-fill: rgba(255,255,255,0.55);
                                                          -fx-background-color: rgba(255,255,255,0.04);
                                                          -fx-background-radius: 12;
                                                          -fx-border-color: rgba(255,255,255,0.10);
                                                          -fx-border-radius: 12; -fx-border-width: 0.5;"/>
                                        <Label text="Email cannot be changed."
                                               style="-fx-text-fill: rgba(255,255,255,0.40); -fx-font-size: 11;"/>

                                        <Label text="Contact number"
                                               style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.65);
                                                      -fx-letter-spacing: 1;"/>
                                        <TextField fx:id="phoneField" promptText="+44 7700 000 000"
                                                   style="-fx-font-size: 13; -fx-padding: 12 14 12 14;
                                                          -fx-text-fill: white;
                                                          -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                          -fx-background-color: rgba(255,255,255,0.06);
                                                          -fx-background-radius: 12;
                                                          -fx-border-color: rgba(255,255,255,0.18);
                                                          -fx-border-radius: 12; -fx-border-width: 0.5;"/>
                                        <Label fx:id="phoneErrorLabel"
                                               style="-fx-text-fill: #fca5a5; -fx-font-size: 11;"/>

                                        <Label text="Delivery address"
                                               style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.65);
                                                      -fx-letter-spacing: 1;"/>
                                        <TextArea fx:id="addressField" prefRowCount="3" wrapText="true"
                                                  style="-fx-font-size: 13; -fx-padding: 4;
                                                         -fx-control-inner-background: rgba(255,255,255,0.06);
                                                         -fx-text-fill: white;
                                                         -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                         -fx-background-color: rgba(255,255,255,0.06);
                                                         -fx-background-radius: 12;
                                                         -fx-border-color: rgba(255,255,255,0.18);
                                                         -fx-border-radius: 12; -fx-border-width: 0.5;"/>

                                        <HBox spacing="10">
                                            <Button text="Save changes"
                                                    onAction="#handleSaveProfile"
                                                    style="-fx-background-color: rgba(255,255,255,0.95);
                                                           -fx-text-fill: #0a0f1f;
                                                           -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                           -fx-font-size: 13; -fx-font-weight: bold;
                                                           -fx-padding: 11 22 11 22; -fx-background-radius: 20;
                                                           -fx-border-color: rgba(255,255,255,0.6);
                                                           -fx-border-radius: 20; -fx-border-width: 0.5;
                                                           -fx-cursor: hand;
                                                           -fx-effect: dropshadow(gaussian, rgba(94,234,212,0.4), 12, 0.2, 0, 3);"/>
                                            <Button fx:id="toggleAccountBtn"
                                                    onAction="#handleToggleAccount"
                                                    style="-fx-background-color: rgba(248,113,113,0.16);
                                                           -fx-text-fill: #fca5a5;
                                                           -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                           -fx-font-size: 13; -fx-font-weight: bold;
                                                           -fx-padding: 11 22 11 22; -fx-background-radius: 20;
                                                           -fx-border-color: rgba(248,113,113,0.35);
                                                           -fx-border-radius: 20; -fx-border-width: 0.5;
                                                           -fx-cursor: hand;"/>
                                        </HBox>
                                    </VBox>

                                    <!-- PREFERENCES TAB -->
                                    <VBox fx:id="preferencesPane" spacing="14" visible="false" managed="false">
                                        <Label fx:id="preferencesMessageLabel"
                                               style="-fx-text-fill: #5eead4; -fx-font-size: 12;"
                                               wrapText="true"/>

                                        <Label text="Robot categories of interest"
                                               style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.65);
                                                      -fx-letter-spacing: 1;"/>
                                        <FlowPane fx:id="categoriesPane" hgap="10" vgap="10"/>

                                        <Label text="Notification preferences"
                                               style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.65);
                                                      -fx-letter-spacing: 1;"/>
                                        <ComboBox fx:id="notificationsCombo" prefWidth="320"
                                                  style="-fx-font-size: 13;
                                                         -fx-background-color: rgba(255,255,255,0.06);
                                                         -fx-background-radius: 12;
                                                         -fx-border-color: rgba(255,255,255,0.18);
                                                         -fx-border-radius: 12; -fx-border-width: 0.5;"/>

                                        <Label text="Delivery instructions"
                                               style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.65);
                                                      -fx-letter-spacing: 1;"/>
                                        <TextArea fx:id="deliveryInstructionsField"
                                                  prefRowCount="3" wrapText="true"
                                                  promptText="Special delivery instructions..."
                                                  style="-fx-font-size: 13; -fx-padding: 4;
                                                         -fx-control-inner-background: rgba(255,255,255,0.06);
                                                         -fx-text-fill: white;
                                                         -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                         -fx-background-color: rgba(255,255,255,0.06);
                                                         -fx-background-radius: 12;
                                                         -fx-border-color: rgba(255,255,255,0.18);
                                                         -fx-border-radius: 12; -fx-border-width: 0.5;"/>

                                        <Button text="Save preferences"
                                                onAction="#handleSavePreferences"
                                                style="-fx-background-color: rgba(255,255,255,0.95);
                                                       -fx-text-fill: #0a0f1f;
                                                       -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                       -fx-font-size: 13; -fx-font-weight: bold;
                                                       -fx-padding: 11 22 11 22; -fx-background-radius: 20;
                                                       -fx-border-color: rgba(255,255,255,0.6);
                                                       -fx-border-radius: 20; -fx-border-width: 0.5;
                                                       -fx-cursor: hand;
                                                       -fx-effect: dropshadow(gaussian, rgba(94,234,212,0.4), 12, 0.2, 0, 3);"/>
                                    </VBox>

                                    <!-- ORDER HISTORY TAB -->
                                    <VBox fx:id="ordersPane" spacing="12" visible="false" managed="false">
                                        <Label text="Synced from RAEZ Orders module · read-only"
                                               style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 12;"/>
                                        <StackPane>
                                            <Pane style="-fx-background-color: rgba(255,255,255,0.04);
                                                         -fx-background-radius: 14;
                                                         -fx-border-color: rgba(255,255,255,0.10);
                                                         -fx-border-radius: 14; -fx-border-width: 0.5;" />
                                            <TableView fx:id="ordersTable" prefHeight="360"
                                                       styleClass="orders-table-dark">
                                                <columns>
                                                    <TableColumn fx:id="colOrderId"   text="Order ID"   prefWidth="110"/>
                                                    <TableColumn fx:id="colRobotType" text="Robot type" prefWidth="200"/>
                                                    <TableColumn fx:id="colDate"      text="Date"       prefWidth="140"/>
                                                    <TableColumn fx:id="colStatus"    text="Status"     prefWidth="140"/>
                                                    <TableColumn fx:id="colAmount"    text="Amount"     prefWidth="120"/>
                                                </columns>
                                            </TableView>
                                        </StackPane>
                                    </VBox>

                                    <!-- MY REVIEWS TAB -->
                                    <VBox fx:id="reviewEligiblePane" spacing="12" visible="false" managed="false">
                                        <Label text="Products eligible for review — delivered in the last 30 days"
                                               style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 12;"/>
                                        <VBox fx:id="eligibleListPane" spacing="10"/>
                                    </VBox>

                                </StackPane>
                            </VBox>
                        </StackPane>

                    </VBox>
                </content>
            </ScrollPane>
        </center>

    </BorderPane>

</StackPane>
