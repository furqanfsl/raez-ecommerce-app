<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.raez.controllers.CartController"
            style="-fx-background-color: #070d18;">

    <BorderPane AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0"
                AnchorPane.topAnchor="0.0">

        <top>
            <fx:include source="ProductHeader.fxml" />
        </top>

        <center>
            <StackPane>

                <!-- Gradient mesh background, like login + dashboard -->
                <Pane style="-fx-background-color: linear-gradient(to bottom right, #0a0f1f 0%, #0d2538 35%, #1a3347 60%, #2a1a4a 100%);"
                      maxWidth="Infinity" maxHeight="Infinity" />
                <Pane style="-fx-background-color: radial-gradient(center 12% 12%, radius 40%, rgba(20,184,166,0.18) 0%, transparent 70%);"
                      maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true" />
                <Pane style="-fx-background-color: radial-gradient(center 88% 80%, radius 45%, rgba(139,92,246,0.20) 0%, transparent 70%);"
                      maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true" />

                <ScrollPane fitToWidth="true"
                            hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <content>
                        <VBox spacing="22" maxWidth="Infinity"
                              style="-fx-background-color: transparent;">
                            <padding><Insets top="32" right="44" bottom="44" left="44"/></padding>

                            <!-- Page header -->
                            <HBox alignment="CENTER_LEFT" spacing="14">
                                <VBox spacing="4">
                                    <Label text="CHECKOUT"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 10; -fx-font-weight: bold;
                                                  -fx-text-fill: #5eead4; -fx-letter-spacing: 3;" />
                                    <Label text="Your cart"
                                           style="-fx-font-family: 'Inter','Segoe UI','Montserrat',sans-serif;
                                                  -fx-font-size: 28; -fx-font-weight: 900; -fx-text-fill: white;" />
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="←  Continue shopping" onAction="#handleBack"
                                        style="-fx-background-color: rgba(255,255,255,0.06);
                                               -fx-text-fill: white;
                                               -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                               -fx-font-size: 12; -fx-font-weight: bold;
                                               -fx-padding: 10 20 10 20;
                                               -fx-background-radius: 22;
                                               -fx-border-color: rgba(255,255,255,0.25);
                                               -fx-border-radius: 22; -fx-border-width: 0.5;
                                               -fx-cursor: hand;" />
                                <Label fx:id="loginStatusLabel"
                                       style="-fx-font-family: 'Inter','Segoe UI',sans-serif; -fx-font-size: 12;" />
                            </HBox>

                            <!-- Two-column body -->
                            <HBox spacing="22">

                                <!-- Items column -->
                                <VBox spacing="14" HBox.hgrow="ALWAYS">

                                    <!-- Empty state -->
                                    <StackPane fx:id="emptyLabelHost" visible="false" managed="false">
                                        <Pane style="-fx-background-color: rgba(13,21,32,0.78);
                                                     -fx-background-radius: 22;
                                                     -fx-border-color: rgba(255,255,255,0.10);
                                                     -fx-border-radius: 22; -fx-border-width: 0.5;
                                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 22, 0.25, 0, 8);" />
                                        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 60 30 60 30;">
                                            <Label text="🛒"
                                                   style="-fx-font-size: 42;" />
                                            <Label fx:id="emptyLabel" text="Your cart is empty."
                                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                          -fx-font-size: 15; -fx-font-weight: bold;
                                                          -fx-text-fill: rgba(255,255,255,0.85);" />
                                            <Label text="Browse the storefront to add a robot."
                                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                          -fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.55);" />
                                        </VBox>
                                    </StackPane>

                                    <VBox fx:id="itemsBox" spacing="12" />
                                </VBox>

                                <!-- Order summary card -->
                                <StackPane prefWidth="360" minWidth="320">
                                    <Pane style="-fx-background-color: rgba(13,21,32,0.85);
                                                 -fx-background-radius: 22;
                                                 -fx-border-color: rgba(255,255,255,0.10);
                                                 -fx-border-radius: 22; -fx-border-width: 0.5;
                                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 22, 0.25, 0, 8);" />

                                    <VBox spacing="14" style="-fx-padding: 26 26 26 26;">

                                        <Label text="ORDER SUMMARY"
                                               style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                      -fx-font-size: 10; -fx-font-weight: bold;
                                                      -fx-text-fill: #5eead4; -fx-letter-spacing: 3;" />

                                        <HBox>
                                            <Label text="Subtotal"
                                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                          -fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.65);"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Label fx:id="subtotalLabel" text="£0.00"
                                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                          -fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                        </HBox>
                                        <HBox>
                                            <Label text="Delivery"
                                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                          -fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.65);"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Label text="Free"
                                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                          -fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #5eead4;"/>
                                        </HBox>

                                        <Pane prefHeight="0.5" maxWidth="Infinity"
                                              style="-fx-background-color: rgba(255,255,255,0.10);"/>

                                        <HBox>
                                            <Label text="Total"
                                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                          -fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Label fx:id="totalLabel" text="£0.00"
                                                   style="-fx-font-family: 'Inter','Segoe UI','Montserrat',sans-serif;
                                                          -fx-font-size: 22; -fx-font-weight: 900; -fx-text-fill: #5eead4;
                                                          -fx-effect: dropshadow(gaussian, rgba(94,234,212,0.5), 12, 0.3, 0, 0);"/>
                                        </HBox>

                                        <Label text="DELIVERY ADDRESS"
                                               style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                      -fx-font-size: 10; -fx-font-weight: bold;
                                                      -fx-text-fill: rgba(255,255,255,0.55); -fx-letter-spacing: 2;
                                                      -fx-padding: 6 0 0 0;"/>
                                        <TextField fx:id="addressField" promptText="House, street, postcode (optional)"
                                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                          -fx-font-size: 13; -fx-padding: 12 14 12 14;
                                                          -fx-text-fill: white;
                                                          -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                          -fx-background-color: rgba(255,255,255,0.06);
                                                          -fx-background-radius: 12;
                                                          -fx-border-color: rgba(255,255,255,0.18);
                                                          -fx-border-radius: 12; -fx-border-width: 0.5;"/>

                                        <Button fx:id="checkoutBtn"
                                                text="Place order →"
                                                onAction="#handleCheckout" maxWidth="Infinity"
                                                style="-fx-background-color: linear-gradient(to right, #5eead4 0%, #38bdf8 100%);
                                                       -fx-text-fill: #06121f;
                                                       -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                       -fx-font-size: 14; -fx-font-weight: bold;
                                                       -fx-padding: 14 0 14 0;
                                                       -fx-background-radius: 22;
                                                       -fx-cursor: hand;
                                                       -fx-effect: dropshadow(gaussian, rgba(94,234,212,0.55), 18, 0.3, 0, 6);"/>

                                        <Button text="Clear cart" onAction="#handleClear" maxWidth="Infinity"
                                                style="-fx-background-color: transparent;
                                                       -fx-text-fill: #fca5a5;
                                                       -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                       -fx-font-size: 12; -fx-font-weight: bold;
                                                       -fx-padding: 10 0;
                                                       -fx-background-radius: 22;
                                                       -fx-border-color: rgba(248,113,113,0.30);
                                                       -fx-border-radius: 22; -fx-border-width: 0.5;
                                                       -fx-cursor: hand;"/>

                                        <Label fx:id="statusLabel" wrapText="true" text=""
                                               style="-fx-font-family: 'Inter','Segoe UI',sans-serif; -fx-font-size: 12;" />

                                        <HBox alignment="CENTER" spacing="10"
                                              style="-fx-border-color: rgba(255,255,255,0.10);
                                                     -fx-border-width: 0.5 0 0 0; -fx-padding: 12 0 0 0;">
                                            <Label text="🔒  256-bit SSL"
                                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                          -fx-font-size: 10; -fx-text-fill: rgba(255,255,255,0.40);"/>
                                            <Label text="·" style="-fx-text-fill: rgba(255,255,255,0.20);"/>
                                            <Label text="GDPR compliant"
                                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                          -fx-font-size: 10; -fx-text-fill: rgba(255,255,255,0.40);"/>
                                            <Label text="·" style="-fx-text-fill: rgba(255,255,255,0.20);"/>
                                            <Label text="Free returns"
                                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                          -fx-font-size: 10; -fx-text-fill: rgba(255,255,255,0.40);"/>
                                        </HBox>

                                    </VBox>
                                </StackPane>
                            </HBox>

                            <fx:include source="AppFooter.fxml"/>

                        </VBox>
                    </content>
                </ScrollPane>
            </StackPane>
        </center>

    </BorderPane>
</AnchorPane>
