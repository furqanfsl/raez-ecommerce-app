<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.raez.controllers.CustomerSignupController">

    <!-- Base gradient mesh: deep blue → teal → violet (matches login + hero) -->
    <Pane style="-fx-background-color: linear-gradient(to bottom right, #0a0f1f 0%, #0d2538 35%, #1a3347 60%, #2a1a4a 100%);"
          maxWidth="Infinity" maxHeight="Infinity" />

    <!-- Mesh blob: teal glow, top-left -->
    <Pane style="-fx-background-color: radial-gradient(center 15% 20%, radius 45%, rgba(20,184,166,0.30) 0%, transparent 70%);"
          maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true" />

    <!-- Mesh blob: violet glow, bottom-right -->
    <Pane style="-fx-background-color: radial-gradient(center 80% 75%, radius 50%, rgba(139,92,246,0.28) 0%, transparent 70%);"
          maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true" />

    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <content>
            <VBox alignment="TOP_CENTER" spacing="0" fillWidth="true"
                  style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="32" right="0" bottom="44" left="0"/>
                </padding>

                <!-- ─── Dark Card ─────────────────────────────────────── -->
                <StackPane maxWidth="520">

                    <Pane style="-fx-background-color: #0d1520;
                                 -fx-background-radius: 24;
                                 -fx-border-color: rgba(255,255,255,0.12);
                                 -fx-border-radius: 24; -fx-border-width: 0.5;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 40, 0.3, 0, 16);" />

                    <VBox spacing="0" style="-fx-padding: 0;">

                        <!-- Header -->
                        <VBox spacing="6" style="-fx-padding: 32 36 22 36;">
                            <Label text="JOIN RAEZ"
                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                          -fx-font-size: 10; -fx-font-weight: bold;
                                          -fx-text-fill: #5eead4; -fx-letter-spacing: 3;" />
                            <Label text="Create your account"
                                   style="-fx-font-family: 'Inter','Segoe UI','Montserrat',sans-serif;
                                          -fx-font-size: 26; -fx-font-weight: 900;
                                          -fx-text-fill: white;" />
                            <Label text="One profile across the storefront, orders, and reviews."
                                   wrapText="true"
                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                          -fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.65);" />
                        </VBox>

                        <!-- Form -->
                        <VBox spacing="16" style="-fx-padding: 0 36 28 36;">

                            <Label fx:id="generalErrorLabel"
                                   wrapText="true" maxWidth="Infinity"
                                   style="-fx-font-size: 12;" />

                            <!-- First / Last name -->
                            <HBox spacing="12">
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="First name"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);
                                                  -fx-letter-spacing: 1;" />
                                    <TextField fx:id="firstNameField" promptText="John" maxWidth="Infinity"
                                               style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                      -fx-font-size: 14; -fx-padding: 12 14 12 14;
                                                      -fx-text-fill: white;
                                                      -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                      -fx-background-color: rgba(255,255,255,0.06);
                                                      -fx-background-radius: 12;
                                                      -fx-border-color: rgba(255,255,255,0.18);
                                                      -fx-border-radius: 12; -fx-border-width: 0.5;" />
                                    <Label fx:id="firstNameErrorLabel"
                                           style="-fx-text-fill: #fca5a5; -fx-font-size: 11;" />
                                </VBox>
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="Last name"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);
                                                  -fx-letter-spacing: 1;" />
                                    <TextField fx:id="lastNameField" promptText="Doe" maxWidth="Infinity"
                                               style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                      -fx-font-size: 14; -fx-padding: 12 14 12 14;
                                                      -fx-text-fill: white;
                                                      -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                      -fx-background-color: rgba(255,255,255,0.06);
                                                      -fx-background-radius: 12;
                                                      -fx-border-color: rgba(255,255,255,0.18);
                                                      -fx-border-radius: 12; -fx-border-width: 0.5;" />
                                    <Label fx:id="lastNameErrorLabel"
                                           style="-fx-text-fill: #fca5a5; -fx-font-size: 11;" />
                                </VBox>
                            </HBox>

                            <!-- Email -->
                            <VBox spacing="7">
                                <Label text="Email"
                                       style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                              -fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);
                                              -fx-letter-spacing: 1;" />
                                <TextField fx:id="emailField" promptText="your@email.com" maxWidth="Infinity"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 14; -fx-padding: 12 14 12 14;
                                                  -fx-text-fill: white;
                                                  -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                  -fx-background-color: rgba(255,255,255,0.06);
                                                  -fx-background-radius: 12;
                                                  -fx-border-color: rgba(255,255,255,0.18);
                                                  -fx-border-radius: 12; -fx-border-width: 0.5;" />
                                <Label fx:id="emailErrorLabel" wrapText="true"
                                       style="-fx-text-fill: #fca5a5; -fx-font-size: 11;" />
                            </VBox>

                            <!-- Phone -->
                            <VBox spacing="7">
                                <Label text="Contact number"
                                       style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                              -fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);
                                              -fx-letter-spacing: 1;" />
                                <TextField fx:id="phoneField" promptText="+44 7700 000 000" maxWidth="Infinity"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 14; -fx-padding: 12 14 12 14;
                                                  -fx-text-fill: white;
                                                  -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                  -fx-background-color: rgba(255,255,255,0.06);
                                                  -fx-background-radius: 12;
                                                  -fx-border-color: rgba(255,255,255,0.18);
                                                  -fx-border-radius: 12; -fx-border-width: 0.5;" />
                                <Label fx:id="phoneErrorLabel"
                                       style="-fx-text-fill: #fca5a5; -fx-font-size: 11;" />
                            </VBox>

                            <!-- Address -->
                            <VBox spacing="7">
                                <Label text="Delivery address"
                                       style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                              -fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);
                                              -fx-letter-spacing: 1;" />
                                <TextArea fx:id="addressField"
                                          promptText="House / flat, street, postcode, city"
                                          prefRowCount="2" wrapText="true" maxWidth="Infinity"
                                          style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                 -fx-font-size: 14; -fx-padding: 4;
                                                 -fx-control-inner-background: rgba(255,255,255,0.06);
                                                 -fx-text-fill: white;
                                                 -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                 -fx-background-color: rgba(255,255,255,0.06);
                                                 -fx-background-radius: 12;
                                                 -fx-border-color: rgba(255,255,255,0.18);
                                                 -fx-border-radius: 12; -fx-border-width: 0.5;" />
                            </VBox>

                            <!-- ID card -->
                            <VBox spacing="8">
                                <Label text="ID card image"
                                       style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                              -fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);
                                              -fx-letter-spacing: 1;" />
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Button text="📁  Upload ID"
                                            onAction="#handleUploadIdCard"
                                            style="-fx-background-color: rgba(255,255,255,0.06);
                                                   -fx-text-fill: white;
                                                   -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                   -fx-font-size: 12; -fx-font-weight: bold;
                                                   -fx-padding: 9 16 9 16; -fx-background-radius: 18;
                                                   -fx-border-color: rgba(255,255,255,0.25);
                                                   -fx-border-radius: 18; -fx-border-width: 0.5;
                                                   -fx-cursor: hand;" />
                                    <Label fx:id="idCardLabel" text="No file selected"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 12;"
                                           HBox.hgrow="ALWAYS" />
                                </HBox>
                                <Label fx:id="idCardErrorLabel"
                                       style="-fx-text-fill: #fca5a5; -fx-font-size: 11;" />
                            </VBox>

                            <!-- Password / Confirm -->
                            <HBox spacing="12">
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="Password"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);
                                                  -fx-letter-spacing: 1;" />
                                    <PasswordField fx:id="passwordField" promptText="Create password" maxWidth="Infinity"
                                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                          -fx-font-size: 14; -fx-padding: 12 14 12 14;
                                                          -fx-text-fill: white;
                                                          -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                          -fx-background-color: rgba(255,255,255,0.06);
                                                          -fx-background-radius: 12;
                                                          -fx-border-color: rgba(255,255,255,0.18);
                                                          -fx-border-radius: 12; -fx-border-width: 0.5;" />
                                    <Label fx:id="passwordErrorLabel"
                                           style="-fx-text-fill: #fca5a5; -fx-font-size: 11;" />
                                </VBox>
                                <VBox spacing="7" HBox.hgrow="ALWAYS">
                                    <Label text="Confirm password"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);
                                                  -fx-letter-spacing: 1;" />
                                    <PasswordField fx:id="confirmPasswordField" promptText="Repeat password" maxWidth="Infinity"
                                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                          -fx-font-size: 14; -fx-padding: 12 14 12 14;
                                                          -fx-text-fill: white;
                                                          -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                          -fx-background-color: rgba(255,255,255,0.06);
                                                          -fx-background-radius: 12;
                                                          -fx-border-color: rgba(255,255,255,0.18);
                                                          -fx-border-radius: 12; -fx-border-width: 0.5;" />
                                    <Label fx:id="confirmPasswordErrorLabel"
                                           style="-fx-text-fill: #fca5a5; -fx-font-size: 11;" />
                                </VBox>
                            </HBox>

                            <!-- Primary CTA -->
                            <Button text="Create my RAEZ account →"
                                    onAction="#handleSignup"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: rgba(255,255,255,0.95);
                                           -fx-text-fill: #0a0f1f;
                                           -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                           -fx-font-size: 14; -fx-font-weight: bold;
                                           -fx-padding: 14 0 14 0;
                                           -fx-background-radius: 20;
                                           -fx-border-color: rgba(255,255,255,0.6);
                                           -fx-border-radius: 20; -fx-border-width: 0.5;
                                           -fx-cursor: hand;
                                           -fx-effect: dropshadow(gaussian, rgba(94,234,212,0.4), 14, 0.25, 0, 4);" />

                            <!-- Footer row -->
                            <HBox alignment="CENTER" spacing="14"
                                  style="-fx-border-color: rgba(255,255,255,0.12);
                                         -fx-border-width: 0.5 0 0 0;
                                         -fx-padding: 14 0 0 0;">
                                <Button text="Back to Login"
                                        onAction="#handleBack"
                                        style="-fx-background-color: transparent;
                                               -fx-text-fill: rgba(255,255,255,0.75);
                                               -fx-border-color: rgba(255,255,255,0.25);
                                               -fx-border-radius: 18; -fx-border-width: 0.5;
                                               -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                               -fx-font-size: 12; -fx-padding: 8 18 8 18;
                                               -fx-cursor: hand;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label text="Encrypted · GDPR compliant"
                                       style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                              -fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.45);" />
                            </HBox>

                        </VBox>
                    </VBox>
                </StackPane>

            </VBox>
        </content>
    </ScrollPane>
</StackPane>
