<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.raez.controllers.CustomerLoginController"
            style="-fx-background-color: #f4f6fb;">

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <content>
                <VBox alignment="CENTER" spacing="0"
                      style="-fx-background-color: #f4f6fb;"
                      minHeight="700" fillWidth="true">
                    <padding>
                        <Insets top="60" right="0" bottom="60" left="0"/>
                    </padding>

                    <!-- Card -->
                    <VBox alignment="TOP_LEFT" spacing="0"
                          maxWidth="460"
                          style="-fx-background-color: white;
                                 -fx-border-color: #e5e7eb; -fx-border-radius: 12;
                                 -fx-background-radius: 12;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 16, 0.2, 0, 4);">

                        <!-- Header bar -->
                        <VBox style="-fx-background-color: #000080;
                                     -fx-padding: 24 28 20 28;
                                     -fx-background-radius: 12 12 0 0;">
                            <Label text="Welcome to RAEZ"
                                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;" />
                            <Label text="Sign in to your customer account"
                                   style="-fx-font-size: 13; -fx-text-fill: #cbd5e1; -fx-padding: 4 0 0 0;" />
                        </VBox>

                        <!-- Form body -->
                        <VBox spacing="16" style="-fx-padding: 28;">

                            <!-- Email -->
                            <VBox spacing="6">
                                <Label text="Email" style="-fx-font-size: 13; -fx-text-fill: #374151;" />
                                <TextField fx:id="emailField"
                                           promptText="your@email.com"
                                           maxWidth="Infinity"
                                           style="-fx-font-size: 14; -fx-padding: 10 14 10 14;
                                                  -fx-border-color: #d1d5db; -fx-border-radius: 8;
                                                  -fx-background-radius: 8; -fx-background-color: white;" />
                                <Label fx:id="emailErrorLabel"
                                       style="-fx-text-fill: #dc2626; -fx-font-size: 11;" />
                            </VBox>

                            <!-- Password -->
                            <VBox spacing="6">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Password"
                                           style="-fx-font-size: 13; -fx-text-fill: #374151;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Hyperlink text="Forgot password?" onAction="#handleForgotPassword"
                                               style="-fx-font-size: 12; -fx-text-fill: #000080;
                                                      -fx-border-color: transparent;" />
                                </HBox>
                                <PasswordField fx:id="passwordField"
                                               promptText="Enter your password"
                                               maxWidth="Infinity"
                                               style="-fx-font-size: 14; -fx-padding: 10 14 10 14;
                                                      -fx-border-color: #d1d5db; -fx-border-radius: 8;
                                                      -fx-background-radius: 8; -fx-background-color: white;" />
                                <Label fx:id="passwordErrorLabel"
                                       style="-fx-text-fill: #dc2626; -fx-font-size: 11;" />
                            </VBox>

                            <!-- General error -->
                            <Label fx:id="generalErrorLabel"
                                   style="-fx-text-fill: #dc2626; -fx-font-size: 12;"
                                   wrapText="true" />

                            <!-- Sign In -->
                            <Button text="Sign In"
                                    onAction="#handleLogin"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #000080; -fx-text-fill: white;
                                           -fx-font-size: 14; -fx-font-weight: bold;
                                           -fx-padding: 12 0; -fx-background-radius: 8;
                                           -fx-cursor: hand;" />

                            <!-- Demo login -->
                            <Button text="Demo Customer Login"
                                    onAction="#handleFillDemo"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #e0e7ff; -fx-text-fill: #000080;
                                           -fx-font-size: 13; -fx-font-weight: bold;
                                           -fx-padding: 10 0; -fx-background-radius: 8;
                                           -fx-cursor: hand;" />

                            <!-- Divider row -->
                            <HBox alignment="CENTER" spacing="14"
                                  style="-fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0;
                                         -fx-padding: 10 0 0 0;">
                                <Button text="Back to Home"
                                        onAction="#handleBack"
                                        style="-fx-background-color: transparent;
                                               -fx-border-color: #d1d5db; -fx-border-radius: 8;
                                               -fx-font-size: 12; -fx-padding: 8 18 8 18;
                                               -fx-cursor: hand;" />
                                <Label text="New to RAEZ?"
                                       style="-fx-font-size: 12; -fx-text-fill: #6b7280;" />
                                <Hyperlink text="Create account" onAction="#handleCreateAccount"
                                           style="-fx-font-size: 12; -fx-text-fill: #000080;
                                                  -fx-border-color: transparent;" />
                            </HBox>

                        </VBox>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
