<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.raez.controllers.CustomerLoginController">

    <!-- Base gradient mesh: deep blue → teal → violet (matches hero) -->
    <Pane style="-fx-background-color: linear-gradient(to bottom right, #0a0f1f 0%, #0d2538 35%, #1a3347 60%, #2a1a4a 100%);"
          maxWidth="Infinity" maxHeight="Infinity" />

    <!-- Mesh blob: teal glow, top-left -->
    <Pane style="-fx-background-color: radial-gradient(center 15% 20%, radius 45%, rgba(20,184,166,0.30) 0%, transparent 70%);"
          maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true" />

    <!-- Mesh blob: violet glow, bottom-right -->
    <Pane style="-fx-background-color: radial-gradient(center 80% 75%, radius 50%, rgba(139,92,246,0.28) 0%, transparent 70%);"
          maxWidth="Infinity" maxHeight="Infinity" mouseTransparent="true" />

    <!-- Scrollable so the card stays centered on small viewports -->
    <ScrollPane fitToWidth="true" fitToHeight="true"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <content>
            <VBox alignment="CENTER" spacing="0" minHeight="700" fillWidth="true"
                  style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="60" right="0" bottom="60" left="0"/>
                </padding>

                <!-- ─── Dark Card ─────────────────────────────────────── -->
                <StackPane maxWidth="460">

                    <!-- Dark solid background -->
                    <Pane style="-fx-background-color: #0d1520;
                                 -fx-background-radius: 24;
                                 -fx-border-color: rgba(255,255,255,0.12);
                                 -fx-border-radius: 24; -fx-border-width: 0.5;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 40, 0.3, 0, 16);" />

                    <!-- ─── Card content ─────────────────────────────────────── -->
                    <VBox spacing="0" style="-fx-padding: 0;">

                        <!-- Header -->
                        <VBox spacing="6" style="-fx-padding: 32 34 22 34;">
                            <Label text="WELCOME BACK"
                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                          -fx-font-size: 10; -fx-font-weight: bold;
                                          -fx-text-fill: #5eead4; -fx-letter-spacing: 3;" />
                            <Label text="Sign in to RAEZ"
                                   style="-fx-font-family: 'Inter','Segoe UI','Montserrat',sans-serif;
                                          -fx-font-size: 26; -fx-font-weight: 900;
                                          -fx-text-fill: white;" />
                            <Label text="Customer portal · autonomous robotics catalogue"
                                   style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                          -fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.65);" />
                        </VBox>

                        <!-- Form -->
                        <VBox spacing="16" style="-fx-padding: 0 34 28 34;">

                            <!-- Email -->
                            <VBox spacing="7">
                                <Label text="Email"
                                       style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                              -fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);
                                              -fx-letter-spacing: 1;" />
                                <TextField fx:id="emailField"
                                           promptText="your@email.com"
                                           maxWidth="Infinity"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 14; -fx-padding: 14 16 14 16;
                                                  -fx-text-fill: white;
                                                  -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                  -fx-background-color: rgba(255,255,255,0.06);
                                                  -fx-background-radius: 14;
                                                  -fx-border-color: rgba(255,255,255,0.18);
                                                  -fx-border-radius: 14; -fx-border-width: 0.5;" />
                                <Label fx:id="emailErrorLabel"
                                       style="-fx-text-fill: #fca5a5; -fx-font-size: 11;" />
                            </VBox>

                            <!-- Password -->
                            <VBox spacing="7">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Password"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.7);
                                                  -fx-letter-spacing: 1;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Hyperlink text="Forgot password?" onAction="#handleForgotPassword"
                                               style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                      -fx-font-size: 12; -fx-text-fill: #5eead4;
                                                      -fx-border-color: transparent;" />
                                </HBox>
                                <PasswordField fx:id="passwordField"
                                               promptText="Enter your password"
                                               maxWidth="Infinity"
                                               style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                      -fx-font-size: 14; -fx-padding: 14 16 14 16;
                                                      -fx-text-fill: white;
                                                      -fx-prompt-text-fill: rgba(255,255,255,0.35);
                                                      -fx-background-color: rgba(255,255,255,0.06);
                                                      -fx-background-radius: 14;
                                                      -fx-border-color: rgba(255,255,255,0.18);
                                                      -fx-border-radius: 14; -fx-border-width: 0.5;" />
                                <Label fx:id="passwordErrorLabel"
                                       style="-fx-text-fill: #fca5a5; -fx-font-size: 11;" />
                            </VBox>

                            <!-- General error -->
                            <Label fx:id="generalErrorLabel"
                                   style="-fx-text-fill: #fca5a5; -fx-font-size: 12;"
                                   wrapText="true" />

                            <!-- Sign In — bright liquid button -->
                            <Button text="Sign In →"
                                    onAction="#handleLogin"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: rgba(255,255,255,0.95);
                                           -fx-text-fill: #0a0f1f;
                                           -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                           -fx-font-size: 14; -fx-font-weight: bold;
                                           -fx-padding: 14 0 14 0;
                                           -fx-background-radius: 20;
                                           -fx-border-color: rgba(255,255,255,0.6);
                                           -fx-border-radius: 20; -fx-border-width: 0.5;
                                           -fx-cursor: hand;
                                           -fx-effect: dropshadow(gaussian, rgba(94,234,212,0.4), 14, 0.25, 0, 4);" />

                            <!-- Demo login — glass chip -->
                            <Button text="Demo Customer Login"
                                    onAction="#handleFillDemo"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: rgba(255,255,255,0.06);
                                           -fx-text-fill: white;
                                           -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                           -fx-font-size: 13; -fx-font-weight: bold;
                                           -fx-padding: 12 0; -fx-background-radius: 20;
                                           -fx-border-color: rgba(255,255,255,0.25);
                                           -fx-border-radius: 20; -fx-border-width: 0.5;
                                           -fx-cursor: hand;" />

                            <!-- Footer row -->
                            <HBox alignment="CENTER" spacing="14"
                                  style="-fx-border-color: rgba(255,255,255,0.12);
                                         -fx-border-width: 0.5 0 0 0;
                                         -fx-padding: 14 0 0 0;">
                                <Button text="Back to Home"
                                        onAction="#handleBack"
                                        style="-fx-background-color: transparent;
                                               -fx-text-fill: rgba(255,255,255,0.75);
                                               -fx-border-color: rgba(255,255,255,0.25);
                                               -fx-border-radius: 18; -fx-border-width: 0.5;
                                               -fx-font-family: 'Inter','Segoe UI',sans-serif;
                                               -fx-font-size: 12; -fx-padding: 8 18 8 18;
                                               -fx-cursor: hand;" />
                                <Label text="New to RAEZ?"
                                       style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                              -fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.6);" />
                                <Hyperlink text="Create account" onAction="#handleCreateAccount"
                                           style="-fx-font-family: 'Inter','Segoe UI',sans-serif;
                                                  -fx-font-size: 12; -fx-text-fill: white;
                                                  -fx-font-weight: bold;
                                                  -fx-border-color: transparent;" />
                            </HBox>

                        </VBox>
                    </VBox>
                </StackPane>

            </VBox>
        </content>
    </ScrollPane>
</StackPane>
