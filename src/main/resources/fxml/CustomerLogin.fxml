<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.CustomerLoginController"
            style="-fx-background-color: white;">

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: white; -fx-background: white; -fx-border-color: transparent;">
            <content>
                <VBox alignment="CENTER" spacing="15"
                      style="-fx-background-color: white;"
                      minHeight="700" fillWidth="true">
                    <padding>
                        <Insets top="60" right="500" bottom="60" left="500"/>
                    </padding>

                    <Label text="RAEZ"
                           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #0F172A;"/>
                    <Label text="Customer Login"
                           style="-fx-text-fill: #6B7280; -fx-font-size: 14px;"/>

                    <Button text="Clear fields"
                            onAction="#handleClearFields"
                            maxWidth="Infinity"
                            style="-fx-background-color: #EFF6FF; -fx-text-fill: #2563EB;
                                   -fx-border-color: #BFDBFE; -fx-border-radius: 6;
                                   -fx-background-radius: 6; -fx-padding: 8;
                                   -fx-font-size: 12px; -fx-cursor: hand;"/>

                    <VBox spacing="3"
                          style="-fx-background-color: #EFF6FF; -fx-padding: 10;
                                 -fx-border-color: #BFDBFE; -fx-border-radius: 6; -fx-background-radius: 6;">
                        <Label text="Use an account from your SQLite database (seeded on first run)."
                               wrapText="true"
                               style="-fx-font-size: 12px; -fx-text-fill: #1E3A8A;"/>
                    </VBox>

                    <Label text="Email" style="-fx-text-fill: #0F172A;"/>
                    <TextField fx:id="emailField"
                               promptText="customer@email.com"
                               maxWidth="Infinity"
                               style="-fx-padding: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    <Label fx:id="emailErrorLabel"
                           style="-fx-text-fill: red; -fx-font-size: 11px;"/>

                    <Label text="Password" style="-fx-text-fill: #0F172A;"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Enter password"
                                   maxWidth="Infinity"
                                   style="-fx-padding: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                    <Label fx:id="passwordErrorLabel"
                           style="-fx-text-fill: red; -fx-font-size: 11px;"/>

                    <Label fx:id="generalErrorLabel"
                           style="-fx-text-fill: red; -fx-font-size: 12px;"
                           wrapText="true"/>

                    <Button text="Login"
                            onAction="#handleLogin"
                            maxWidth="Infinity"
                            style="-fx-background-color: #3B82F6; -fx-text-fill: white;
                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-padding: 12 0; -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <Button text="Back to Home"
                            onAction="#handleBack"
                            maxWidth="Infinity"
                            style="-fx-background-color: transparent; -fx-border-color: #E2E8F0;
                                   -fx-border-radius: 8; -fx-font-size: 13px;
                                   -fx-padding: 12 0; -fx-cursor: hand;"/>

                    <Button text="Create Account"
                            onAction="#handleCreateAccount"
                            style="-fx-background-color: transparent; -fx-text-fill: #2563EB;
                                   -fx-font-size: 12px; -fx-cursor: hand;"/>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
