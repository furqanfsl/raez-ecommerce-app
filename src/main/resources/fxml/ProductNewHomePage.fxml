<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.Group?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Polygon?>
<?import javafx.scene.shape.Line?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.raez.controllers.ProductNewHomePageController"
      spacing="0"
      maxWidth="Infinity">

    <!-- ═══════════════ HERO SECTION — full width ═══════════════ -->
    <StackPane fx:id="heroPane" prefHeight="460" maxWidth="Infinity" minWidth="0">

        <!-- Dark navy gradient background -->
        <Pane style="-fx-background-color: linear-gradient(to bottom right, #1E2939, #161F2B 55%, #2D3E52);"
              maxWidth="Infinity" maxHeight="Infinity" />

        <!-- Optional hero image at low opacity -->
        <ImageView fx:id="heroImage"
                   fitWidth="800" fitHeight="460"
                   preserveRatio="false" smooth="true"
                   opacity="0.12" />

        <!-- Radial glow overlay -->
        <Pane maxWidth="Infinity" maxHeight="Infinity"
              style="-fx-background-color: radial-gradient(center 30% 50%, radius 60%, rgba(45,62,82,0.6), transparent);" />

        <!-- Hero content: text left, robot right -->
        <HBox alignment="CENTER_LEFT" maxWidth="Infinity" minWidth="0"
              style="-fx-padding: 0 32 30 32;">

            <!-- Left: headline text + CTAs -->
            <VBox fx:id="heroTextBox" spacing="14" maxWidth="580" HBox.hgrow="NEVER">
                <Label text="FLAGSHIP COLLECTION"
                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #a5b4fc;
                              -fx-letter-spacing: 3;" />
                <Label text="Apex Automata:"
                       wrapText="true" maxWidth="560"
                       style="-fx-font-size: 48; -fx-font-weight: bold; -fx-text-fill: white;
                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 12, 0.15, 0, 3);" />
                <Label text="The Kinetic Series"
                       wrapText="true" maxWidth="560"
                       style="-fx-font-size: 36; -fx-font-weight: bold;
                              -fx-text-fill: linear-gradient(to right, #60a5fa, #00d4ff);
                              -fx-effect: dropshadow(gaussian, rgba(0,212,255,0.35), 18, 0.2, 0, 0);" />
                <Label text="Precision-engineered AI companions for the new era. From security to service — discover the future, kinetically realised."
                       wrapText="true" maxWidth="500"
                       style="-fx-font-size: 13; -fx-text-fill: #cbd5e1; -fx-line-spacing: 3;" />
                <HBox spacing="14" style="-fx-padding: 10 0 0 0;">
                    <Button text="Explore Collection →" onAction="#handleExploreCollection"
                            style="-fx-background-color: white; -fx-text-fill: #1E2939;
                                   -fx-font-size: 13; -fx-font-weight: bold;
                                   -fx-padding: 11 26; -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 8, 0, 0, 3);" />
                    <Button text="Shop Now" onAction="#handleShopNow"
                            style="-fx-background-color: transparent; -fx-text-fill: white;
                                   -fx-font-size: 13; -fx-font-weight: bold;
                                   -fx-padding: 11 26; -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-border-color: rgba(255,255,255,0.55); -fx-border-radius: 8;
                                   -fx-border-width: 1.5;" />
                </HBox>
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Right: robot animation -->
            <StackPane fx:id="robotContainer" prefWidth="300" prefHeight="440" minWidth="0"
                       HBox.hgrow="NEVER">
                <Group fx:id="robotGroup">

                    <!-- Back glow plate -->
                    <Circle fx:id="backGlow"
                            centerX="0" centerY="0" radius="170"
                            style="-fx-fill: radial-gradient(center 50% 50%, radius 50%, rgba(0,212,255,0.22), transparent);" />

                    <!-- Antenna -->
                    <Line startX="0" startY="-228" endX="0" endY="-196"
                          stroke="#7dd3fc" strokeWidth="3" />
                    <Circle fx:id="antennaTip"
                            centerX="0" centerY="-236" radius="7"
                            fill="#00d4ff"
                            style="-fx-effect: dropshadow(gaussian, #00d4ff, 14, 0.9, 0, 0);" />

                    <!-- Head -->
                    <Polygon fx:id="headShape"
                             fill="#0f1e33" stroke="#3b82f6" strokeWidth="2"
                             points="-52.0,-190.0,52.0,-190.0,72.0,-150.0,52.0,-110.0,-52.0,-110.0,-72.0,-150.0"
                             style="-fx-effect: dropshadow(gaussian, #3b82f6, 20, 0.5, 0, 0);" />

                    <!-- Eyes -->
                    <Rectangle fx:id="eyeLeft"
                               x="-36" y="-162" width="22" height="12" arcWidth="8" arcHeight="8"
                               fill="#00d4ff"
                               style="-fx-effect: dropshadow(gaussian, #00d4ff, 14, 1.0, 0, 0);" />
                    <Rectangle fx:id="eyeRight"
                               x="14" y="-162" width="22" height="12" arcWidth="8" arcHeight="8"
                               fill="#00d4ff"
                               style="-fx-effect: dropshadow(gaussian, #00d4ff, 14, 1.0, 0, 0);" />

                    <!-- Mouth grille -->
                    <Rectangle x="-22" y="-132" width="44" height="4" arcWidth="2" arcHeight="2"
                               fill="#1e3a8a" />

                    <!-- Neck -->
                    <Rectangle x="-14" y="-110" width="28" height="14" fill="#1e3a8a" />

                    <!-- Chest plate -->
                    <Rectangle x="-72" y="-96" width="144" height="140" arcWidth="18" arcHeight="18"
                               fill="#0f1e33" stroke="#3b82f6" strokeWidth="2"
                               style="-fx-effect: dropshadow(gaussian, #1e40af, 14, 0.35, 0, 0);" />

                    <!-- Reactor core -->
                    <Circle fx:id="reactorCore"
                            centerX="0" centerY="-30" radius="22"
                            stroke="#60a5fa" strokeWidth="1.5"
                            style="-fx-fill: radial-gradient(center 50% 50%, radius 50%, #00d4ff, #1e40af);
                                   -fx-effect: dropshadow(gaussian, #00d4ff, 20, 0.85, 0, 0);" />
                    <Circle centerX="0" centerY="-30" radius="7" fill="white" opacity="0.7" />

                    <!-- Status triangles -->
                    <Polygon fill="#34d399" points="-50.0,20.0,-40.0,20.0,-45.0,10.0" />
                    <Polygon fill="#60a5fa" points="40.0,20.0,50.0,20.0,45.0,10.0" />

                    <!-- Left shoulder + arm -->
                    <Circle centerX="-80" centerY="-84" radius="12" fill="#1e40af" />
                    <Rectangle fx:id="armLeft"
                               x="-102" y="-76" width="22" height="72" arcWidth="8" arcHeight="8"
                               fill="#0f1e33" stroke="#1e40af" strokeWidth="1.5" />
                    <Rectangle x="-106" y="-4" width="30" height="48" arcWidth="6" arcHeight="6"
                               fill="#1e3a8a" stroke="#3b82f6" strokeWidth="1" />

                    <!-- Right shoulder + arm -->
                    <Circle centerX="80" centerY="-84" radius="12" fill="#1e40af" />
                    <Rectangle fx:id="armRight"
                               x="80" y="-76" width="22" height="72" arcWidth="8" arcHeight="8"
                               fill="#0f1e33" stroke="#1e40af" strokeWidth="1.5" />
                    <Rectangle x="76" y="-4" width="30" height="48" arcWidth="6" arcHeight="6"
                               fill="#1e3a8a" stroke="#3b82f6" strokeWidth="1" />

                    <!-- Waist band -->
                    <Rectangle x="-60" y="44" width="120" height="16" arcWidth="6" arcHeight="6"
                               fill="#1e3a8a" />

                    <!-- Scanning pulse bar -->
                    <Rectangle fx:id="pulseBar"
                               x="-66" y="30" width="12" height="4" arcWidth="2" arcHeight="2"
                               style="-fx-fill: linear-gradient(to right, #3b82f6, #00d4ff);" />

                    <!-- Legs -->
                    <Rectangle x="-44" y="60" width="32" height="82" arcWidth="6" arcHeight="6"
                               fill="#0f1e33" stroke="#1e40af" strokeWidth="1.5" />
                    <Rectangle x="-48" y="142" width="40" height="16" arcWidth="6" arcHeight="6"
                               fill="#1e3a8a" />
                    <Rectangle x="12" y="60" width="32" height="82" arcWidth="6" arcHeight="6"
                               fill="#0f1e33" stroke="#1e40af" strokeWidth="1.5" />
                    <Rectangle x="8" y="142" width="40" height="16" arcWidth="6" arcHeight="6"
                               fill="#1e3a8a" />

                </Group>
            </StackPane>

        </HBox>
    </StackPane>

    <!-- ═══════════════ PRODUCT STRIPS SECTION ═══════════════ -->
    <VBox fx:id="stripsContainer"
          spacing="8" maxWidth="Infinity" minWidth="0"
          style="-fx-background-color: white; -fx-padding: 36 32 20 32;" />

</VBox>
