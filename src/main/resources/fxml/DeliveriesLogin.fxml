<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.raez.delivery.controller.DeliveryDashboardController"
      style="-fx-background-color: linear-gradient(to bottom right, #eff6ff, #bfdbfe);">
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Delivery Tracking System" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

    <VBox spacing="12" maxWidth="360" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 24; -fx-border-color: #dbeafe; -fx-border-radius: 14;">
        <Label text="Sign in to access your dashboard" style="-fx-font-size: 15px; -fx-text-fill: #6b7280;"/>

        <Label text="Email Address"/>
        <TextField fx:id="emailField" promptText="admin@delivery.com"/>

        <Label text="Password"/>
        <PasswordField fx:id="passwordField" promptText="Enter your password"/>

        <Label fx:id="errorLabel" style="-fx-text-fill: #dc2626;"/>

        <Button text="Sign In" onAction="#handleLogin"
                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"
                maxWidth="1.7976931348623157E308"/>

    </VBox>
</VBox>