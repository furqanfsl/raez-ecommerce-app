<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.raez.controllers.ProductFormDialogController"
      prefWidth="580"
      style="-fx-background-color: white; -fx-border-color: #e5e7eb;
             -fx-border-radius: 8; -fx-background-radius: 8;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 16, 0.2, 0, 4);">

    <!-- Header -->
    <HBox style="-fx-background-color: #f9fafb; -fx-padding: 20 24 20 24;
                 -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;
                 -fx-background-radius: 8 8 0 0;" alignment="CENTER_LEFT">
        <Label fx:id="dialogTitle" text="Add New Product"
               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #111827;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="✕" onAction="#handleClose"
                style="-fx-background-color: transparent; -fx-border-color: transparent;
                       -fx-font-size: 16; -fx-text-fill: #9ca3af; -fx-cursor: hand;" />
    </HBox>

    <!-- Scrollable form body -->
    <ScrollPane fitToWidth="true" prefHeight="520" VBox.vgrow="ALWAYS"
                style="-fx-background-color: white; -fx-border-color: transparent;">
        <content>
            <VBox style="-fx-padding: 24;" spacing="20">

                <!-- Error box -->
                <VBox fx:id="errorBox" visible="false" managed="false"
                      style="-fx-background-color: #fef2f2; -fx-border-color: #fecaca;
                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 12;"
                      spacing="4">
                    <Label fx:id="errorLabel" text="" wrapText="true"
                           style="-fx-font-size: 12; -fx-text-fill: #dc2626;" />
                </VBox>

                <!-- Product Name -->
                <VBox spacing="6">
                    <Label text="Product Name *"
                           style="-fx-font-size: 13; -fx-text-fill: #374151;" />
                    <TextField fx:id="nameField"
                               promptText="e.g., Smart Home Assistant Bot"
                               style="-fx-font-size: 13; -fx-padding: 10 14 10 14;
                                      -fx-border-color: #d1d5db; -fx-border-radius: 6;
                                      -fx-background-radius: 6;" />
                </VBox>

                <!-- Description -->
                <VBox spacing="6">
                    <Label text="Description"
                           style="-fx-font-size: 13; -fx-text-fill: #374151;" />
                    <TextArea fx:id="descriptionField"
                              promptText="Enter product description..."
                              prefRowCount="4"
                              style="-fx-font-size: 13; -fx-padding: 10 14 10 14;
                                     -fx-border-color: #d1d5db; -fx-border-radius: 6;
                                     -fx-background-radius: 6;" />
                </VBox>

                <!-- Price + Stock -->
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Price (£) *"
                               style="-fx-font-size: 13; -fx-text-fill: #374151;" />
                        <TextField fx:id="priceField" promptText="0.00"
                                   style="-fx-font-size: 13; -fx-padding: 10 14 10 14;
                                          -fx-border-color: #d1d5db; -fx-border-radius: 6;
                                          -fx-background-radius: 6;" />
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Stock Quantity *"
                               style="-fx-font-size: 13; -fx-text-fill: #374151;" />
                        <TextField fx:id="stockField" promptText="0"
                                   style="-fx-font-size: 13; -fx-padding: 10 14 10 14;
                                          -fx-border-color: #d1d5db; -fx-border-radius: 6;
                                          -fx-background-radius: 6;" />
                    </VBox>
                </HBox>

                <!-- Collection assignment -->
                <VBox spacing="8">
                    <Label text="Collection"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;" />
                    <ComboBox fx:id="collectionCombo" maxWidth="Infinity"
                              style="-fx-font-size: 13; -fx-text-fill: white; -fx-background-color: #1f2937; -fx-border-color: #4b5563; -fx-border-radius: 6; -fx-background-radius: 6;" />
                    <Label text="Tip: The product tagged 'Main Robot' in a collection is its flagship shown at the top of the collection page."
                           wrapText="true"
                           style="-fx-font-size: 11; -fx-text-fill: #6b7280;" />
                </VBox>

                <!-- Categories -->
                <VBox spacing="8">
                    <Label text="Category / Flagship Role"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;" />
                    <CheckBox fx:id="catMainRobot" text="Main Robot  ★  (Flagship — shown at the top of its collection page)"
                              style="-fx-font-size: 13;" />
                    <CheckBox fx:id="catMiniRobot" text="Mini Robot"
                              style="-fx-font-size: 13;" />
                    <CheckBox fx:id="catAccessory"  text="Accessory"
                              style="-fx-font-size: 13;" />
                    <CheckBox fx:id="catService"    text="Service"
                              style="-fx-font-size: 13;" />
                </VBox>

                <!-- Local Product Images -->
                <VBox spacing="8">
                    <Label text="Product Images"
                           style="-fx-font-size: 13; -fx-text-fill: #374151;" />
                    <HBox spacing="8">
                        <Button text="Browse Local Image"
                                onAction="#handleBrowseLocalImage"
                                style="-fx-background-color: #111827; -fx-text-fill: white;
                                       -fx-border-radius: 6; -fx-background-radius: 6;
                                       -fx-font-size: 13; -fx-padding: 10 16 10 16; -fx-cursor: hand;" />
                        <TextField fx:id="selectedImageField"
                                   promptText="No file selected"
                                   editable="false"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-font-size: 13; -fx-padding: 10 14 10 14;
                                          -fx-border-color: #d1d5db; -fx-border-radius: 6;
                                          -fx-background-radius: 6;" />
                    </HBox>
                    <!-- Live preview: shows currently primary image (blank dark glass otherwise) -->
                    <StackPane fx:id="imagePreviewFrame"
                               prefWidth="540" prefHeight="220"
                               style="-fx-background-color: linear-gradient(to bottom right, #0a0f1f, #121a2e, #1a2744);
                                      -fx-background-radius: 10;
                                      -fx-border-color: #d1d5db; -fx-border-radius: 10; -fx-border-width: 0.5;">
                        <Label fx:id="imagePreviewPlaceholder" text="No image selected"
                               style="-fx-font-size: 12; -fx-text-fill: #9ca3af;" />
                        <ImageView fx:id="imagePreview"
                                   fitWidth="540" fitHeight="220"
                                   preserveRatio="true" smooth="true" />
                    </StackPane>
                    <VBox fx:id="imageListBox" spacing="6" />
                    <Label text="Tip: The most recent image becomes the primary shown on the storefront."
                           style="-fx-font-size: 11; -fx-text-fill: #9ca3af;" />
                </VBox>

                <!-- Status -->
                <VBox spacing="8">
                    <Label text="Status" style="-fx-font-size: 13; -fx-text-fill: #374151;" />
                    <HBox spacing="24">
                        <fx:define>
                            <ToggleGroup fx:id="statusGroup" />
                        </fx:define>
                        <RadioButton text="Active"   toggleGroup="$statusGroup"
                                     fx:id="statusActive" selected="true"
                                     style="-fx-font-size: 13;" />
                        <RadioButton text="Inactive" toggleGroup="$statusGroup"
                                     fx:id="statusInactive"
                                     style="-fx-font-size: 13;" />
                    </HBox>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>

    <!-- Footer buttons -->
    <HBox style="-fx-padding: 16 24 16 24; -fx-border-color: #e5e7eb;
                 -fx-border-width: 1 0 0 0;" spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleClose"
                style="-fx-background-color: white; -fx-border-color: #e5e7eb;
                       -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-font-size: 13; -fx-padding: 9 20 9 20; -fx-cursor: hand;" />
        <Button fx:id="submitBtn" text="Add Product" onAction="#handleSubmit"
                style="-fx-background-color: #111827; -fx-text-fill: white;
                       -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-font-size: 13; -fx-font-weight: bold;
                       -fx-padding: 9 20 9 20; -fx-cursor: hand;" />
    </HBox>
</VBox>
