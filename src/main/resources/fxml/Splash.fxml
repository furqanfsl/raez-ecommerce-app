<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.media.MediaView?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.raez.controllers.SplashController"
           fx:id="splashRoot"
           prefWidth="1280" prefHeight="800"
           style="-fx-background-color: #000000;">

    <!-- Full-screen video background — no overlay, no text -->
    <MediaView fx:id="videoView"
               fitWidth="1280" fitHeight="800"
               preserveRatio="false" />

</StackPane>
