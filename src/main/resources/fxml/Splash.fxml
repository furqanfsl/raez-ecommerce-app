<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.raez.controllers.SplashController"
           fx:id="splashRoot"
           prefWidth="1280" prefHeight="800"
           style="-fx-background-color: #080818;">

    <!-- Radial glow in center -->
    <Pane style="-fx-background-color: radial-gradient(center 50% 46%, radius 35%,
                     rgba(0,80,255,0.18) 0%, transparent 100%);"
          maxWidth="Infinity" maxHeight="Infinity" />

    <!-- Main content stack -->
    <VBox alignment="CENTER" spacing="24">

        <!-- Word row: starts as Z E A R → animates to R A E Z -->
        <HBox alignment="CENTER" spacing="12">
            <Label fx:id="letter0" text="Z"
                   style="-fx-font-size: 130; -fx-font-weight: bold; -fx-text-fill: white;
                          -fx-effect: dropshadow(gaussian, rgba(0,100,255,0.6), 20, 0.3, 0, 0);" />
            <Label fx:id="letter1" text="E"
                   style="-fx-font-size: 130; -fx-font-weight: bold; -fx-text-fill: white;
                          -fx-effect: dropshadow(gaussian, rgba(0,100,255,0.6), 20, 0.3, 0, 0);" />
            <Label fx:id="letter2" text="A"
                   style="-fx-font-size: 130; -fx-font-weight: bold; -fx-text-fill: white;
                          -fx-effect: dropshadow(gaussian, rgba(0,100,255,0.6), 20, 0.3, 0, 0);" />
            <Label fx:id="letter3" text="R"
                   style="-fx-font-size: 130; -fx-font-weight: bold; -fx-text-fill: white;
                          -fx-effect: dropshadow(gaussian, rgba(0,100,255,0.6), 20, 0.3, 0, 0);" />
        </HBox>

        <!-- Subtitle -->
        <Label fx:id="subtitleLabel" text="NEXT-GENERATION AI ROBOTICS"
               style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #60a5fa;
                      -fx-letter-spacing: 4;" />

    </VBox>

    <!-- Bottom loading hint -->
    <Label text="Calibrating identity matrix…"
           StackPane.alignment="BOTTOM_CENTER"
           style="-fx-font-size: 11; -fx-text-fill: #334155; -fx-padding: 0 0 24 0;" />

</StackPane>
