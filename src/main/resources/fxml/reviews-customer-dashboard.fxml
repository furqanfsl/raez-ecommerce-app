<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.raez.reviews.controller.CustomerDashboardController"
            fitToWidth="true" fitToHeight="false" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED"
            styleClass="app-shell,dashboard-scroll">
    <content>
        <BorderPane minHeight="760" minWidth="980" prefWidth="1180" styleClass="dashboard-layout">
            <top>
                <VBox spacing="12" styleClass="hero-panel">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20" />
                    </padding>
                    <Label text="Customer Review Workspace" styleClass="page-title" />
                    <Label fx:id="welcomeLabel" styleClass="page-subtitle" />
                    <FlowPane hgap="12" vgap="12" prefWrapLength="960">
                        <TextField fx:id="searchField" prefWidth="320" promptText="Search products by name or category" />
                        <ComboBox fx:id="productComboBox" prefWidth="280" promptText="Select a product" />
                        <ComboBox fx:id="sortComboBox" prefWidth="180" />
                        <Button text="Refresh" onAction="#handleRefresh" styleClass="secondary-button" />
                        <Button text="Logout" onAction="#handleLogout" styleClass="secondary-button" />
                    </FlowPane>
                    <FlowPane hgap="16" vgap="12" prefWrapLength="960">
                        <Label fx:id="averageRatingLabel" styleClass="badge-text" />
                        <Label fx:id="reviewCountLabel" styleClass="badge-text" />
                        <Label fx:id="eligibilityLabel" styleClass="badge-text" wrapText="true" />
                    </FlowPane>
                </VBox>
            </top>
            <center>
                <SplitPane orientation="VERTICAL" dividerPositions="0.66" prefHeight="560">
                    <BorderPane.margin>
                        <Insets top="16" right="0" bottom="16" left="0" />
                    </BorderPane.margin>
                    <items>
                        <TableView fx:id="reviewTable" minHeight="300">
                            <columns>
                                <TableColumn fx:id="reviewerColumn" text="Reviewer" />
                                <TableColumn fx:id="ratingColumn" text="Rating" />
                                <TableColumn fx:id="commentColumn" text="Comment" />
                                <TableColumn fx:id="helpfulColumn" text="Helpful" />
                                <TableColumn fx:id="unhelpfulColumn" text="Unhelpful" />
                                <TableColumn fx:id="statusColumn" text="Status" />
                                <TableColumn fx:id="createdColumn" text="Created" />
                            </columns>
                        </TableView>
                        <VBox spacing="10" styleClass="panel-card">
                            <padding>
                                <Insets top="12" right="12" bottom="12" left="12" />
                            </padding>
                            <Label text="Rating Distribution" styleClass="section-title" />
                            <BarChart fx:id="ratingChart" legendVisible="false" categoryGap="10" minHeight="240" prefHeight="260">
                                <xAxis>
                                    <CategoryAxis label="Star bucket" />
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Reviews" />
                                </yAxis>
                            </BarChart>
                        </VBox>
                    </items>
                </SplitPane>
            </center>
            <bottom>
                <VBox spacing="12" styleClass="panel-card">
                    <padding>
                        <Insets top="16" right="20" bottom="16" left="20" />
                    </padding>
                    <Label fx:id="editWindowLabel" styleClass="muted-text" wrapText="true" />
                    <FlowPane hgap="10" vgap="10" prefWrapLength="960">
                        <Button fx:id="addReviewButton" text="Add Review" onAction="#handleAddReview" styleClass="primary-button" />
                        <Button fx:id="editReviewButton" text="Edit Selected" onAction="#handleEditReview" styleClass="secondary-button" />
                        <Button fx:id="deleteReviewButton" text="Delete Selected" onAction="#handleDeleteReview" styleClass="secondary-button" />
                        <Button fx:id="helpfulButton" text="Helpful" onAction="#handleHelpfulVote" styleClass="secondary-button" />
                        <Button fx:id="unhelpfulButton" text="Unhelpful" onAction="#handleUnhelpfulVote" styleClass="secondary-button" />
                    </FlowPane>
                </VBox>
            </bottom>
        </BorderPane>
    </content>
</ScrollPane>
