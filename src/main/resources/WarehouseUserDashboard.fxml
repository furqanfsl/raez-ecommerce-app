<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/13"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Ecommerce1.Ecommerce1.Warehouse_UserDashboardController"
            styleClass="root">

    <!-- Top header -->
    <top>
        <HBox spacing="12" styleClass="topbar" alignment="CENTER_LEFT">
            <padding>
                <Insets top="16" right="24" bottom="16" left="24"/>
            </padding>
            <Label text="Product Catalogue Overview" styleClass="h1"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Log Out" onAction="#onLogout" styleClass="danger-button"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding>
                <Insets top="16" right="24" bottom="16" left="24"/>
            </padding>

            <!-- Filters card -->
            <VBox spacing="10" styleClass="card">
                <padding>
                    <Insets top="12" right="12" bottom="12" left="12"/>
                </padding>
                <TextField fx:id="searchField" promptText="Search product..."/>
                <HBox spacing="12">
                    <ComboBox fx:id="categoryCombo"  promptText="Filter by Category" prefWidth="260"/>
                    <ComboBox fx:id="warehouseCombo" promptText="Filter by Warehouse" prefWidth="260"/>
                </HBox>
            </VBox>

            <!-- Table card -->
            <VBox spacing="8" styleClass="card">
                <padding>
                    <Insets top="12" right="12" bottom="12" left="12"/>
                </padding>

                <TableView fx:id="productsTable" prefHeight="520">
                    <columns>
                        <TableColumn fx:id="nameCol"      text="Product Name"       prefWidth="300"/>
                        <TableColumn fx:id="qtyCol"       text="Available Quantity" prefWidth="160"/>
                        <TableColumn fx:id="warehouseCol" text="Warehouse Location" prefWidth="280"/>
                        <TableColumn fx:id="statusCol"    text="Stock Status"       prefWidth="160"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

        </VBox>
    </center>

</BorderPane>
