<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.OrdersController"
            style="-fx-background-color: #f8fafc;">

    <top>
        <HBox spacing="10" style="-fx-background-color: white; -fx-border-color: #e5e7eb;">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>
            <Label text="Delivery Management" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="Back to Dashboard" onAction="#goBack"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Search deliveries..." HBox.hgrow="ALWAYS"/>
                <Button text="Add Delivery" onAction="#toggleForm"/>
                <Button text="Open Selected Delivery" onAction="#openSelectedOrder"/>
            </HBox>

            <VBox fx:id="addOrderFormBox" spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 10;">
                <Label text="Add New Delivery" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <TextField fx:id="customerField" promptText="Order ID (leave blank to auto-generate)"/>
                <TextField fx:id="addressField" promptText="Customer Address"/>
                <ComboBox fx:id="statusComboBox"/>
                <ComboBox fx:id="driverComboBox"/>
                <TextField fx:id="itemsField" promptText="Number of Items"/>
                <HBox spacing="10">
                    <Button text="Add" onAction="#addOrder"/>
                    <Button text="Cancel" onAction="#toggleForm"/>
                </HBox>
            </VBox>

            <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol" text="Delivery ID" prefWidth="120"/>
                    <TableColumn fx:id="customerCol" text="Order ID" prefWidth="120"/>
                    <TableColumn fx:id="addressCol" text="Customer Address" prefWidth="260"/>
                    <TableColumn fx:id="statusCol" text="Order Status" prefWidth="140"/>
                    <TableColumn fx:id="driverCol" text="Delivery ID" prefWidth="100"/>
                    <TableColumn fx:id="itemsCol" text="Items" prefWidth="100"/>
                    <TableColumn fx:id="dateCol" text="Order Date" prefWidth="180"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>